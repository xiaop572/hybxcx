.TimeSection .active {
  background: rgb(5, 110, 254);
  color: #fff;
  box-shadow: 0 0 6px #fff inset;
}

.probg {
  background: #fff;
  width: 94%;
  padding: 4rpx 0 0 0;
  margin: 30rpx auto 0 auto;
  border-radius: 20rpx;
