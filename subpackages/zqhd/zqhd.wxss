.msListTop {
  width: 100%;
  display: block;
}

.promain {
  overflow: hidden;
  background: url("https://wx.pmc-wz.com/materials/hwnhjbg.png") no-repeat, linear-gradient(to bottom, 255, 161, 103);
  background-size: 100%;
  padding-bottom: 160rpx;
}

.TimeSection {
  background-color: #fff;
  width: 94%;
  margin: auto;
  border-radius: 40rpx;
  height: 60rpx;
  font-size: 22rpx;
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

