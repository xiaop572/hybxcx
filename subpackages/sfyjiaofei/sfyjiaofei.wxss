/* subpackages/sfyjiaofei/sfyjiaofei.wxss */
.row {
  border:1px solid #ddd;
  background-color: #fff;
  width: 90%;
  margin:40rpx auto 0 auto;
  padding: 10rpx 20rpx;
}

.row text {
  display: inline-block;
  vertical-align: middle;
  border-right: 1px solid #ccc;
  padding-right:40rpx;
}
.row input{
  width: 380rpx;
  display: inline-block;
  vertical-align: middle;
  margin-left: 20rpx;
  padding:10rpx 0;
}
.nextBtn{
  background-color: #5e9be0;
  color: #fff;
  width: 92%;
  margin:40rpx auto;
  text-align: center;
  padding:10rpx 0;
  border-radius: 10rpx;
}
.brinfo{
  width: 90%;
  margin: auto;
  font-size: 26rpx;
}