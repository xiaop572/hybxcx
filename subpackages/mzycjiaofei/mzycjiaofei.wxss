/* subpackages/mzycjiaofei/mzycjiaofei.wxss */
.yccap{
  margin: 50rpx 5%;
  border-left: 5px solid #5e9be0;
  padding-left: 20rpx;
}
.brinfo{
  width: 90%;
  box-shadow: 0 0 3px 2px #ddd;
  margin: auto;
  padding: 20rpx 0;
  border-radius: 10rpx;
}
.infoitem{
  width: 90%;
  margin:0 auto 10rpx auto;
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
}
.nextBtn{
  background-color: #5e9be0;
  color: #fff;
  width: 92%;
  margin:40rpx auto;
  text-align: center;
  padding:10rpx 0;
  border-radius: 10rpx;
}