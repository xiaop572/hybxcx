.navBox {
  /* 顶部tab盒子样式 */
  width: 90%;
  margin: auto;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 5%;
  position: relative;
  border-bottom: 1px solid #eee;
  line-height: 90rpx;
}

.navBox view {
  /* 最后一个tab标题的样式 */
  padding-left: 10%;
}

.navBox view:first-child {
  /* 最后一个tab标题的样式 */
  padding-left: 0;
}

.titleBox {
  /* 未选中文字的样式 */
  color: #666666;
  font-size: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  letter-spacing: 3rpx;
}

.lineBox,
.notLineBox {
  /* 选中及未选中底线共同样式 */
  width:70rpx;
  height: 8rpx;
  color: #883e8b;
}

.fontColorBox,
.fontColorBox1 {
  /* 文字默认颜色 */
  color: #883e8b;
  font-size: 36rpx;
  font-weight: 600;
}

.lineBox {
  /* 选中底线样式 */
  background: #883e8b;
  margin-top: -5rpx;
  border-radius: 4rpx;
}
.hulist{
