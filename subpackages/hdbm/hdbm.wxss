/* subpackages/hdbm/hdbm.wxss */
.banner {
  width: 100%;
}

/* pages/realInfo/readlInfo.wxss */
page {
  height: 100%;
  padding-bottom: 0 !important;
}

.streamer {
  display: block;
  width: 100%;
  text-align: center;
  font-size: 14px;
  padding: 10rpx 0;
  height: 60rpx;
  line-height: 60rpx;
  background: #f7e6c8;
  color: red;
}

.inputLine {
  overflow: hidden;
}

.inputLine text {
  display: block;
  padding: 0 20rpx;
  font-size: 14px;
}

.inputLine input {
  height: 2.6rem;
  padding: 0 20rpx;
  border-top: 1px solid #eee;
  border-bottom: 1px solid #eee;
}

button {
  width: 86% !important;
  margin-top: 40rpx;
}

.yinsi {
  color: blue;
  display: inline;
}

.footer {
  position: fixed;
  width: 100%;
  height: 80rpx;
  bottom: 0;
  left: 0;
  background: #555;
  max-width: 750px;
  right: 0;
  margin: auto;
}

.sum {
  float: right;
  line-height: 80rpx;
  background: #07c160;
  width: 100px;
  text-align: center;
  color: #fff;
  font-size: 20px;
}