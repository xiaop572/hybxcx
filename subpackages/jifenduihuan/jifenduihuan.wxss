/* subpackages/jifenduihuan/jifenduihuan.wxss */
page {
  background-color: #f2f2f2;
  height: 100%;
}

.header {
  height: 160rpx;
  background: linear-gradient(to right, #03a7fd, #015cf5);
}

.jifen {
  font-size: 32rpx;
  color: #fff;
  line-height: 160rpx;
  margin-left: 80rpx;
}

.jifen text {
  font-size: 70rpx;
  margin-right: 30rpx;
}

.jplist {
  background: #fff;
  width: 310rpx;
  float: left;
  border-radius: 30rpx;
  overflow: hidden;
  margin-top: 50rpx;
  margin-left: 45rpx;
  margin-right: -10rpx;
  font-size: 28rpx;
  position: relative;
  padding-bottom: 10rpx;
}

.jpImg {
  width: 100%;
}

.jpcaption {
  font-weight: bold;
  font-size: 26rpx;
  overflow: hidden;
  display: -webkit-box;
  /*弹性伸缩盒子*/
  -webkit-box-orient: vertical;
  /*子元素垂直排列*/
  -webkit-line-clamp: 2;
  /*可以显示的行数，超出部分用...表示*/
  text-overflow: ellipsis;
  padding: 0 10rpx;
  /*（多行文本的情况下，用省略号“…”隐藏溢出范围的文本)*/
}

.jiazhi {
  color: #666;
  font-size: 22rpx;
  margin-left: 20rpx;
  display: block;
  margin-top: -3rpx;
}

.dhjifen {
  color: #666;
  font-size: 26rpx;
  margin-left: 20rpx;
  display: block;
  margin-top: -10rpx;
}

.dhjifen text {
  color: #015cf5;
  font-size: 40rpx;
  margin-right: 10rpx;
}

.dhBtn {
  background-color: #015cf5;
  color: #fff;
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 5rpx 20rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
}
.guize{
  font-size: 28rpx !important;
  vertical-align: middle;
  position: absolute;
  right: 0;
  top: 20rpx;
}