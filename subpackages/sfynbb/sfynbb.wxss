/* pages/realInfo/readlInfo.wxss */
page{
  background-color: #f2f2f2;
  padding-bottom: 80rpx;
}
.streamer{
  display: block;
  width: 100%;
  text-align: center;
  font-size: 14px;
  padding: 10rpx 0;
  height: 60rpx;
  line-height: 60rpx;
  background: #f7e6c8;
  color: red;
}
.inputLine{
  overflow: hidden;
  background: #fff;
  width: 100%;
  display: block;
  margin-top: 20rpx;
}
.inputLine text{
  padding: 20rpx;
  font-size: 14px;
  vertical-align: middle;
  color:red;
}
.inputcap{
  margin: 20rpx 0;
}
.inputLine input{
  height: 2.6rem;
  padding: 0 50rpx;
  border-bottom: 1px solid #eee;
  
}
button{
  width: 86% !important;
  margin-top: 40rpx;
}
.yinsi{
  color: blue;
  display: inline;
}
.footer{
  width: 100%;
  position: absolute;
  bottom: 0;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
}
.cap{
  text-align: center;
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin: 40rpx 0;
}
.picker{
  color: #999;
  padding:0 50rpx 10rpx 50rpx;
  font-size: 32rpx;
}
.picker2{
  color:#000;
  padding:0 50rpx 10rpx 50rpx;
  font-size: 32rpx;
}
.submitBtn {
  color: #fff;
  background-color: rgb(15, 111, 209);
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  letter-spacing: 10rpx;
  border-radius: 10rpx;
  margin:60rpx auto;
  font-size: 26rpx;
}
.weui-cell{
  padding: 0;
}