/* subpackages/qiyeHome/qiyeHome.wxss */
page{
  height: 100%;
  background-color: #f2f2f2;
  background-image: url("https://wx.pmc-wz.com/materials/qyHomeBg.png");
  background-size: 100%;
  background-repeat: no-repeat;
  padding-bottom: 0 !important;
}
.userinfo {
  margin: 60rpx 0 0 50rpx;
  position: relative;
}

.userinfo .acator {
  width: 100rpx;
  border-radius: 95rpx;
  vertical-align: middle;
  margin-right: 30rpx;
}

.userinfo text {
  font-size: 30rpx;
  color: #fff;
}
.yueBox{
  width: 90%;
  height: 250rpx;
  background: #4d4c52;
  border-radius: 30rpx;
  margin:30rpx auto;
  position: relative;
  overflow: hidden;
}
.tiBtn{
  position: absolute;
  right: 0;
  background-color: #e7c59f;
  padding:0 10rpx 0 20rpx;
  border-radius: 20rpx 0 0 20rpx;
  font-size: 26rpx;
  margin-top: 20rpx;
}
.yueList{
  color: #e7c59f;
}
.yuCaption{
  display: block;
}
.ketiCaption{
  display: block;
}
.yueLeft,.ketiRight{
  display: inline-block;
  text-align: center;
}
.yueList{
  text-align: center;
  margin-top: 90rpx;
}

.yueLeft{
  padding-right: 100rpx;
  border-right: 1px solid #e7c59f;
}
.ketiRight{
  padding-left: 100rpx;
}
.yueList .yunum{
  display: block;
  margin-top: 10rpx;
}
.protj{
  margin: auto;
  text-align: center;
  font-size: 40rpx;
  color: #000;
  position: relative;
}
.protj::before{
  display: block;
  content: "";
  background: #cacaca;
  height: 1rpx;
  width: 200rpx;
  position: absolute;
  left: 10%;
  top: 30rpx;
}
.protj::after{
  display: block;
  content: "";
  background: #cacaca;
  height: 1rpx;
  width: 200rpx;
  position: absolute;
  right: 10%;
  top: 30rpx;
}
.navBox {
  /* 顶部tab盒子样式 */
  width: 100%;
  margin:30rpx auto 0 auto;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background-color: #fafafa;
  
}

.navBox view {
  /* 最后一个tab标题的样式 */
  padding-left: 10%;
}

.navBox view:first-child {
  /* 最后一个tab标题的样式 */
  padding-left: 0;
}

.titleBox {
  /* 未选中文字的样式 */
  color: #6f6f6f;
  font-size: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  letter-spacing: 3rpx;
}
.proBox{
  overflow: hidden;
  background: #fafafa;
  padding-bottom: 120rpx;
}
.lineBox,
.notLineBox {
  /* 选中及未选中底线共同样式 */
  width: 70%;
  height: 8rpx;
  color: #2c68fa;
  margin-top: 8rpx;
}

.fontColorBox,
.fontColorBox1 {
  /* 文字默认颜色 */
  color: #2c68fa;
  font-size: 36rpx;
  font-weight: 600;
}

.lineBox {
  /* 选中底线样式 */
  background: #2c68fa;
  border-radius: 4rpx;
}

.jplist {
  background: #fff;
  width: 310rpx;
  float: left;
  border-radius: 30rpx;
  overflow: hidden;
  margin-top: 50rpx;
  margin-left: 45rpx;
  margin-right: -10rpx;
  font-size: 28rpx;
  position: relative;
  padding-bottom: 10rpx;
  height: 440rpx;
}

.jpImg {
  width: 100%;
  height: 310rpx !important;
}

.jpcaption {
  color: #5f5f5f;
  font-weight: bold;
  font-size: 24rpx;
  overflow: hidden;
  display: -webkit-box;
  /*弹性伸缩盒子*/
  -webkit-box-orient: vertical;
  /*子元素垂直排列*/
  -webkit-line-clamp: 1;
  /*可以显示的行数，超出部分用...表示*/
  text-overflow: ellipsis;
  padding: 0 20rpx;
  /*（多行文本的情况下，用省略号“…”隐藏溢出范围的文本)*/
}

.jiazhi {
  color: #333;
  font-size: 24rpx;
  margin-left: 20rpx;
  display: block;
  padding-top: 5rpx;
  border-top: 1px solid #eee;
  margin-right: 20rpx;
}
.yongjin{
  color: #015cf5;
  font-weight: bold;
  font-size: 22rpx;
  margin-left: 20rpx;
  display: block;
  padding-top: 0rpx;
  margin-right: 20rpx;
}
.dhjifen {
  color: #666;
  font-size: 26rpx;
  margin-left: 20rpx;
  display: block;
  margin-top: -10rpx;
}

.dhjifen text {
  color: #015cf5;
  font-size: 40rpx;
  margin-right: 10rpx;
}

.dhBtn {
  background-color: #015cf5;
  color: #fff;
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 5rpx 20rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
}
.guize{
  font-size: 28rpx !important;
  vertical-align: middle;
  position: absolute;
  right: 0;
  top: 20rpx;
}
.swiperTtemBox {
  height: calc(100% - 100rpx);
  overflow: scroll;
  font-size: 28rpx;
  -webkit-overflow-scrolling: touch;
}
.xieyi{
  position: absolute;
  right: 50rpx;
  top: 70rpx;
}