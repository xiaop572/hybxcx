/* huodongpage/fskq/fskq.wxss */
page{
  padding-bottom: 0 !important;
  background-color: #C92615;
}
.neirong{
  position: absolute;
  top: 200rpx;
  left: 0;
  right: 0;
  margin: auto;
  width: 70%;
}
.fskqkq{
  width: 100%;
}
.fskqbtn{
  width: 300rpx;
  display: block;
  margin: auto;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.input-group {
  margin-bottom: 30rpx;
  background: #f0f5ff;
  border-radius: 10rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
}

.label {
  width: 180rpx;
  font-size: 24rpx;
  color: #666;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.share-btn {
  width: 100% !important;
  background: #1875FF;
  color: #fff;
  border-radius: 40rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  font-weight: normal;
}
.btnlist{
  display: flex;
  justify-content: center;
}
