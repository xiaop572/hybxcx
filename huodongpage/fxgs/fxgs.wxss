/* huodongpage/fxgs/fxgs.wxss */
page {
  background: #FFE1E1;
  min-height: 100vh;
}

.page {
  padding-bottom: 60rpx;
}

/* 顶部粉色标题区：只包含标题图 */
.top-section {
  background: #FF8996;
  width: 90%;
  margin: 60rpx auto 0 auto;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  padding: 40rpx 0;
}

.top-title-img {
  width: 68%;
  display: block;
  margin: auto;

}

/* 白色大卡片：紧接粉色区域下方 */
.form-card {
  width: 90%;
  margin: 0 auto;
  background: #fff;
  border-radius: 0 0 30rpx 30rpx;
  padding: 40rpx 36rpx 56rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 30rpx rgba(233, 30, 99, 0.08);
}

/* 说明文字区 */
.desc-box {
  text-align: center;
  padding-bottom: 36rpx;
}

.desc-text {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 2;
}

.desc-reward {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-top: 4rpx;
  line-height: 2;
}

.reward-red {
  color: #e84c6c;
  font-weight: bold;
}

/* 分隔线 */
.divider {
  width: 100%;
  height: 2rpx;
  background: #f5f5f5;
  margin-bottom: 40rpx;
}

/* 表单组 */
.form-group {
  margin-bottom: 36rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

/* 单行输入框 */
.input {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

/* 多行文本域 */
.textarea {
  width: 100%;
  height: 260rpx;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}

.placeholder {
  color: #c8c8c8;
}

/* 蓝色渐变提交按钮 */
.submit-btn {
  display: block;
  width: 80% !important;
  box-sizing: border-box;
  background: linear-gradient(to bottom, #5ab4e8, #016ff5);
  color: #fff;
  font-size: 30rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  border: none;
  font-weight: 0;
  margin-top: 100rpx;
  margin-bottom: 30rpx;
  letter-spacing: 4rpx;
  padding: 0;
  white-space: nowrap;
  overflow: visible;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.88;
}

/* 提交成功弹框遮罩 */
.success-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 弹框主体：浅蓝渐变背景 */
.success-modal {
  width: 580rpx;
  background: linear-gradient(160deg, #e8f5ff 0%, #d0eaff 100%);
  border-radius: 32rpx;
  padding: 56rpx 48rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 提交成功标题 */
.success-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #e84c6c;
  margin-bottom: 40rpx;
  letter-spacing: 4rpx;
}

/* 二维码外框：蓝色圆角边框 */
.qrcode-wrap {
  width: 380rpx;
  padding: 16rpx;
  border: 6rpx solid #3d9fd9;
  border-radius: 28rpx;
  background: #fff;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.qrcode-img {
  width: 100%;
  display: block;
  border-radius: 12rpx;
}

/* 说明文字 */
.success-desc {
  text-align: center;
}

.success-desc-line {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.9;
}

/* 关闭按钮 */
.success-close {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.25);
  color: #fff;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 36rpx;
}
