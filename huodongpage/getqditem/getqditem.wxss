.welcome-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.85);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}
.welcome-popup {
  width: 600rpx;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  position: relative;
}

.welcome-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 40rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 10rpx;
}
.card-img {
  width: 85%;
  border-radius: 15rpx;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  margin-bottom: 20rpx;
}
.welcome-card {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 50rpx;
  backdrop-filter: blur(10rpx);
  display: flex;
  justify-content: center;
  align-items: center;
}

.welcome-card-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 4rpx;
}

.welcome-button {
  background: linear-gradient(to right, #a1b5e2, #355DB5);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 20rpx 80rpx;
  border-radius: 60rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 255, 255, 0.35);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
  letter-spacing: 2rpx;
  border: none;
  outline: none;
  width: 180rpx;
  margin: auto;
  margin-top: 40rpx;
}

.welcome-button:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(255, 122, 61, 0.5);
  background: linear-gradient(135deg, #FF6B2B, #E64A19);
}