/* huodongpage/tjsrhd/tjsrhd.wxss *//* huodongpage/ckhb/ckhb.wxss */
page {
  padding-bottom: 0 !important;
}

.bg {
  display: block;
  width: 100%;
}

.containers {
  position: relative;
}

.main {
  position: absolute;
  top: 0;
  width: 100%;
  text-align: center;
}
.logo{
  width: 20%;
  position: absolute;
  top: 40rpx;
  left: 60rpx;
}
.cap{
  width: 78%;
  margin-top: 130rpx;
}
.lh {
  width: 98% !important;
  margin-top: 670rpx;
  background:none !important;
}
.lh image{
  width: 100% !important;
}
.ymjpro{
  width: 70%;
  margin-top: 40rpx;
}
.shade {
  position: fixed;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
  background-color: rgba(0, 0, 0, 0.7);
}

.card {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  margin: auto;
  width: 600rpx;
  height: 650rpx;
  animation: imgAni 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

@keyframes imgAni {
  0% {
    opacity: 0;
    transform: scale(0);
  }
  
  40% {
    opacity: 0.9;
    transform: scale(1.1);
  }
  
  70% {
    opacity: 1;
    transform: scale(0.95);
  }
  
  90% {
    opacity: 1;
    transform: scale(1.02);
  }
  
  100% {
    opacity: 1;
    transform: scale(1);
  }
}
.close{
  width: 70rpx;
  position: absolute;
  right: 90rpx;
  top: 300rpx;
  z-index: 999
}

/* 表单弹框样式 */
.form-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.form-content {
  width: 600rpx;
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.form-item {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
}

.form-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.phone-btn {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  background-color: #f8f8f8;
  font-size: 28rpx;
  color: #666;
  text-align: left;
  padding: 0 20rpx;
  line-height: 80rpx;
}

.form-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

.form-btn {
  width: 240rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background-color: #ff6b6b;
  color: white;
}