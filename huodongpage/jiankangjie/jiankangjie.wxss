/* huodongPage/jiankangjie/jiankangjie.wxss */
page{
  padding-bottom: 0 !important;
}
.main{
  background:linear-gradient(to bottom,#e4f1f7,#ecdce9,#e6e6f0,#ebd3e3);
}
.topBanner{
  width: 100%;
}
.zxBox{
  text-align: center;
  border: 1px solid #f96679;
  width: 80%;
  border-radius:40rpx;
  padding: 60rpx 0  60rpx 0;
  margin:0 auto 60rpx auto; 
  overflow: hidden;
}
.caption{
  position: relative;
  background-color: #f96679;
  display: inline-block;
  padding-left: 80rpx;
  margin: auto;
  border-radius: 40rpx;
  padding-right: 40rpx;
  color: #fff;
  font-weight: bold;
  font-size: 34rpx;
  letter-spacing: 5rpx;
}
.caption image{
  position: absolute;
  width: 120rpx;
  left: -35rpx;
  top: -60rpx;
}
.address{
  width: 80%;
  margin: 60rpx auto 0 auto;
  display: block;
  padding-bottom: 60rpx;
}
.kapic{
  width: 50%;
  margin-top: 0rpx;
}
.kapic:nth-child(2n-1){
  margin-right: 0rpx;
}
.proList{
  padding: 0 10rpx;
  margin-top: 30rpx;
  text-align: left;
}