/* huodongpage/sqqxlist/sqqxlist.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 20rpx;
}

.header {
  padding: 20rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.list-container {
  width: 100%;
}

.list-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column; /* Changed to column layout */
  align-items: flex-start;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.item-info {
  width: 100%;
  margin-bottom: 20rpx; /* Add space between info and actions */
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.apply-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.status {
  font-size: 24rpx;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-pending {
  color: #ff9900;
  background-color: #fff7e6;
}

.status-approved {
  color: #07c160;
  background-color: #e6f9ef;
}

.status-rejected {
  color: #fa5151;
  background-color: #feeiei;
}

.action-buttons {
  width: 100%;
  display: flex;
  justify-content: flex-end; /* Align buttons to right */
  gap: 20rpx;
  margin-top: 10rpx;
}

.btn {
  font-size:30rpx;
  padding: 16rpx 100rpx; /* Increased padding slightly */
  margin: 0;
  border-radius: 40rpx;
  text-align: center;
  width: auto !important; /* Prevent full width */
  font-weight: normal;
}

.btn.approve {
  background-color: #07c160;
  color: #fff;
}

.btn.reject {
  background-color: #f2f2f2;
  color: #666;
}

.audit-result {
  width: 100%;
  text-align: right;
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 10rpx;
}

.text-approve {
  color: #07c160;
}

.text-reject {
  color: #fa5151;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* Modal Styles */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
  z-index: 1001;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.role-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.role-item {
  padding: 24rpx;
  text-align: center;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
}

.role-item.active {
  border-color: #07c160;
  color: #07c160;
  background-color: #e6f9ef;
  font-weight: 500;
}

.modal-footer {
  display: flex;
  gap: 30rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height:2;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin: 0;
}

.modal-btn.cancel {
  background-color: #f2f2f2;
  color: #666;
}

.modal-btn.confirm {
  background-color: #07c160;
  color: #fff;
}