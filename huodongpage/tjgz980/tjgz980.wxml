
<!-- 获得福卡弹窗 -->
<view class="welcome-overlay">
  <view class="welcome-popup">
    <view class="welcome-title">恭喜您！获得一张{{cardInfo.name}}</view>
    <view class="card-wrapper">
      <image src="https://wx.pmc-wz.com/materials/980gznf.png" mode="widthFix" class="card-img"/>
    </view>
    <image src="https://wx.pmc-wz.com/materials/nanhuibtn.png" mode="widthFix" class="cardbtn" bindtap="openClaimForm"/>
  </view>
</view>

<view class="claim-mask" wx:if="{{showClaimForm}}" bindtap="hideClaimForm">
  <view class="claim-modal" catchtap="preventBubble">
    <view class="claim-title">填写领取信息</view>
    <view class="claim-item">
      <view class="claim-label">姓名</view>
      <input class="claim-input" placeholder="请输入您的姓名" bindinput="onNameInput" value="{{claimName}}" />
    </view>
    <view class="claim-item">
      <view class="claim-label">手机号</view>
      <view class="claim-phone-row">
        <text class="claim-phone-text {{claimPhone ? '' : 'placeholder'}}">{{claimPhone || '点击右侧一键获取'}}</text>
        <button class="claim-phone-btn" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">一键获取</button>
      </view>
    </view>
    <view class="claim-actions">
      <view class="claim-cancel" bindtap="hideClaimForm">取消</view>
      <view class="claim-confirm" bindtap="claimCard">确认领取</view>
    </view>
  </view>
</view>

  
