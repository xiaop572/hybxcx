/* huodongpage/fskq/fskq.wxss */
page{
  padding-bottom: 0 !important;
  background-color: #ADDBF3;
}
.neirong{
  position: absolute;
  top: 200rpx;
  left: 0;
  right: 0;
  margin: auto;
  width: 96%;
}
.fskqkq{
  width: 82%;
  display: block;
  margin: auto;
}
.fskqbtn{
  width: 400rpx;
  display: block;
  margin: auto;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  width: 90%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.input-group {
  margin-bottom: 30rpx;
  background: #f0f5ff;
  border-radius: 10rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
}

.label {
  width: 180rpx;
  font-size: 24rpx;
  color: #666;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.share-btn {
  width: 100% !important;
  background: #1875FF;
  color: #fff;
  border-radius: 40rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  font-weight: normal;
}
.btnlist{
  width: 80%;
  display: flex;
  justify-content: center;
  position: absolute;
  bottom: -120rpx;
  left: 0;
  right: 0;
  margin: auto;
}

/* 手机号一键获取行 */
.phone-row {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  overflow: hidden;
}

.phone-val {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.phone-val.placeholder {
  color: #bbb;
  font-size: 26rpx;
}

.get-phone-btn {
  flex-shrink: 0;
  width: 160rpx !important;
  min-width: 0 !important;
  height: 60rpx !important;
  line-height: 60rpx !important;
  background: #145D8B;
  color: #fff !important;
  font-size: 24rpx !important;
  border-radius: 30rpx !important;
  border: none !important;
  margin: 0 0 0 16rpx !important;
  padding: 0 !important;
}

.get-phone-btn::after {
  border: none;
}

/* 领取弹窗 */
.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.cancel-btn {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  border: none;
}

.cancel-btn::after {
  border: none;
}

.confirm-btn {
  flex: 1;
  background: linear-gradient(90deg, #145D8B, #145D8B);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  font-weight: bold;
  border: none;
}

.confirm-btn::after {
  border: none;
}
