<!--subpageB/weiguangka/weiguangka.wxml-->
<image src="https://wx.pmc-wz.com/materials/hmb/wgkbg.png" mode="widthFix" style="width: 100%;"/>
<image src="https://wx.pmc-wz.com/materials/hmb/wgkbtn.png" mode="widthFix" class="wgkbtn" bindtap="showModal"/>

<!-- 弹框 -->
<view class="modal" wx:if="{{showModalFlag}}">
  <view class="modal-mask" bindtap="hideModal"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">预约信息</text>
      <text class="modal-close" bindtap="hideModal">×</text>
    </view>
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入姓名" value="{{formData.name}}" bindinput="onNameInput"/>
      </view>
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input class="form-input" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="onPhoneInput" type="number"/>
        <button class="get-phone-btn" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">一键获取</button>
      </view>
      <view class="form-item">
        <text class="form-label">预约日期</text>
        <picker mode="date" value="{{formData.date}}" start="{{today}}" bindchange="onDateChange">
          <view class="picker-view">
            <text class="picker-text">{{formData.date || '请选择日期'}}</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="modal-footer">
      <button class="cancel-btn" bindtap="hideModal">取消</button>
      <button class="submit-modal-btn" bindtap="submitModalForm">确认预约</button>
    </view>
  </view>
</view>