page {
  padding-bottom: 0 !important;
  position: relative;
}

image {
  display: block;
}

/* 底部报名框样式 */
.signup-form {
  position: absolute;
  bottom: 160rpx;
  left: 0;
  width: 90%;
  background-color: #fff;
  /* 改为白色背景 */
  padding: 40rpx;
  /* 增加内边距 */
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  /* 调整阴影 */
  z-index: 100;
  box-sizing: border-box;
  right: 0;
  margin: auto;
}

.form-item {
  margin-bottom: 15rpx;
  border-bottom: 1rpx solid #ccc;
  position: relative;
  /* 添加相对定位以便绝对定位label */
}

.form-item label {
  position: absolute;
  left: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #888;
  z-index: 1;
  line-height: 1;
}

form {
  overflow: hidden;
}

.form-item input {
  /* background-color: #fff; */
  /* 移除背景色 */
  height: 70rpx;
  border: none;
  padding: 0 10rpx 0 100rpx;
  font-size: 28rpx;
  border-radius: 0;
  line-height: 70rpx;
}

.form-item textarea {
  height: 120rpx;
  border: none;
  font-size: 28rpx;
  border-radius: 0;
  line-height: 30rpx;
  resize: none;
  vertical-align: top;
  box-sizing: border-box;
}

.submit-btn {
  margin: 30rpx auto 0;
  /* 调整外边距 */
  width: 80%;
  /* 增加宽度 */
  text-align: center;
  padding: 15rpx 30rpx;
  /* 调整内边距 */
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  background: rgb(15, 101, 222);
  box-shadow: 0 4rpx 12rpx rgba(46, 130, 219, 0.3);
  color: #fff;
}

.wgkbtn {
  position: absolute;
  bottom: 60rpx;
  width: 50%;
  left: 0;
  right: 0;
  margin: auto;
  cursor: pointer;
}

/* 弹框样式 - 参考转发有礼页面设计 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.modal-content {
  width: 600rpx;
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
  position: relative;
}

.modal-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background-color 0.3s;
}

.modal-close:active {
  background-color: rgba(0, 0, 0, 0.1);
}

.modal-body {
  margin-bottom: 40rpx;
}

.modal-body .form-item {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
}

.form-input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #ff6b6b;
}

.get-phone-btn {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  background-color: #ff6b6b;
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  cursor: pointer;
  transition: opacity 0.3s;
  border: none;
  outline: none;
  line-height: 1;
  z-index: 10;
  width: 140rpx !important;
}

.get-phone-btn:active {
  opacity: 0.8;
}

.picker-view {
  flex: 1;
  height: 80rpx;
  border-radius: 10rpx;
  padding: 0 20rpx;
  background-color: #f8f8f8;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  width: 300rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  width: 100%;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
}

.submit-modal-btn {
  width: 240rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ff6b6b;
  color: white;
  border: none;
  transition: opacity 0.3s;
}

.submit-modal-btn:active {
  opacity: 0.8;
}

.cancel-btn {
  width: 240rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  color: #666;
  border: none;
  transition: opacity 0.3s;
}

.cancel-btn:active {
  opacity: 0.8;
}