
page{
  padding-bottom: 0 !important;
}
.welcome-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.85);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}
.welcome-popup {
  width: 600rpx;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  position: relative;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFF8C8;
  margin-bottom: 50rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 2rpx;
  line-height: 1.5;
}

.card-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 50rpx;
}

.card-img {
  width: 70%;
  max-width: 400rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
}
.welcome-card {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 50rpx;
  backdrop-filter: blur(10rpx);
  display: flex;
  justify-content: center;
  align-items: center;
}

.welcome-card-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 4rpx;
}

.welcome-button {
  background: linear-gradient(135deg, #FA482A, #FC774B);
  color: #fff;
  font-size: 32rpx;
  padding: 20rpx 60rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 122, 61, 0.4);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
  letter-spacing: 4rpx;
  border: none;
  outline: none;
  margin: 0 auto;
  width: 160rpx;
}

.welcome-button:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 15rpx rgba(255, 122, 61, 0.5);
  background: linear-gradient(135deg, #FF6B2B, #E64A19);
}

/* 未中奖祝福弹窗样式 */
.blessing-popup {
  width: 600rpx;
  border-radius: 30rpx;
  padding: 50rpx 40rpx 60rpx;
  text-align: center;
  position: relative;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

.blessing-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #C44500;
  line-height: 1.4;
  position: relative;
  top:120rpx;
  white-space: pre-line;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  z-index: 20;
}

.blessing-text.already-drawn {
  font-size: 34rpx;
  top: 100rpx;
  font-weight: bold;
  color: #C44500;
  letter-spacing: 2rpx;
}
.jihui{
  position: absolute;
  margin-top: 50rpx;
  font-size: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #C44500;
  z-index: 30;
}

.blessing-image-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 50rpx;
  position: relative;
}

.blessing-image {
  width: 75%;
  max-width: 420rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
}

.blessing-button {
  background: linear-gradient(135deg, #FA4727, #FE764C);
  color: #fff;
  font-size: 32rpx;
  padding: 18rpx 100rpx;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 122, 61, 0.4);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.3;
}

.blessing-button .button-line1 {
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.blessing-button .button-line2 {
  font-size: 30rpx;
  letter-spacing: 4rpx;
}

.blessing-button:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 15rpx rgba(255, 122, 61, 0.5);
  background: linear-gradient(135deg, #FF6B2B, #E64A19);
}