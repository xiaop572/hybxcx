/* huodongpage/ckhb/ckhb.wxss */
page {
  padding-bottom: 0 !important;
}

.bg {
  display: block;
  width: 100%;
}

.containers {
  position: relative;
}

.main {
  position: absolute;
  top: 0;
  width: 100%;
  text-align: center;
}
.logo{
  width: 20%;
  position: absolute;
  top: 40rpx;
  left: 60rpx;
}
.cap{
  width: 78%;
  margin-top: 130rpx;
}
.lh {
  width: 70%;
  margin-top: 200rpx;
}
.ymjpro{
  width: 70%;
  margin-top: 40rpx;
}
.shade {
  position: fixed;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
  background-color: rgba(0, 0, 0, 0.7);
}

.card {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  margin: auto;
  width: 100%;
  animation: imgAni 1s linear;
}

@keyframes imgAni {
  0% {
    width: 0;
    height: 0
  }

  20% {
    width: 500rpx;
    height: 550rpx;
  }
  60% {
    width: 400rpx;
    height: 450rpx;
  }
  80% {
    width: 700rpx;
    height: 750rpx;
  }
  100% {
    width: 600rpx;
    height: 650rpx;
  }
}
.close{
  width: 70rpx;
  position: absolute;
  right: 120rpx;
  top: 170rpx;
  z-index: 999
}