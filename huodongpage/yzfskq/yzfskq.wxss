/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  width: 90%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.input-group {
  margin-bottom: 30rpx;
  background: #f0f5ff;
  border-radius: 10rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
}

.label {
  width: 180rpx;
  font-size: 24rpx;
  color: #666;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.share-btn {
  width: 100% !important;
  background: #1875FF;
  color: #fff;
  border-radius: 40rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  font-weight: normal;
}

/* 列表弹窗特定样式 */
.list-content {
  height: 70%;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  z-index: 40;
}

.list-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.list-scroll {
  flex: 1;
  overflow-y: auto;
}

.list-item {
  background: #f0f5ff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 1px solid #eee;
}

.item-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  align-items: center; /* 确保垂直居中 */
}

.item-row:last-child {
  margin-bottom: 0;
}

.item-label {
  color: #666;
  width: 140rpx;
}

.item-value {
  color: #333;
  flex: 1;
}

.item-value-row {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: space-between; /* 让状态文字和按钮分开 */
}

.reshare-btn {
  font-size: 24rpx;
  color: #1875FF;
  background: #fff;
  border: 1px solid #1875FF;
  padding: 0 20rpx;
  line-height: 48rpx;
  height: 48rpx;
  margin: 0;
  border-radius: 24rpx;
  min-height: 0;
  width: auto !important;
  font-weight: normal;
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-data {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 28rpx;
}
