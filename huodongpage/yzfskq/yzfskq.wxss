page{
  padding-bottom: 0 !important;
  background-color: #ADDBF3;
}
.neirong{
  position: absolute;
  top: 200rpx;
  left: 0;
  right: 0;
  margin: auto;
  width: 96%;
}
.wdzs{
  position: absolute;
  bottom: 320rpx;
  right: 0;
  width: 150rpx;
  z-index: 30;
}
.fskqkq{
  width: 84%;
