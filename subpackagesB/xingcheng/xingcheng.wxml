<view class="yihchengBox">
  <text class="yichengCap">您的演讲议程安排如下</text>
  <text class="yichengCapY">Your Specific Agenda for The Meeting is as Follows</text>
  <view class="yclist" wx:for="{{jbyj}}" wx:for-item="item" wx:key="id">
    <text class="yctime">{{item.content}} {{item.typename}}</text>
    <text class="ychc">演讲会场：{{item.classname}}</text>
    <text class="yczt" wx:if="{{item.title!=='和平国际医院分会场'}}">演讲主题：{{item.title}}</text>
  </view>
</view>
<view class="yihchengBox">
  <text class="yichengCap">您的主持议程安排如下</text>
  <text class="yichengCapY">The agenda for your chairmanship is as follows</text>
  <view class="yclist" wx:for="{{jbzc}}" wx:for-item="item" wx:key="id">
    <text class="yctime">{{item.riqi}} {{item.shijian}}</text>
    <text class="yczt" wx:if="{{item.title!=='和平国际医院分会场'}}">演讲主题：{{item.typename}}</text>
  </view>
</view>
