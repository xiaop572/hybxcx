<!--subpackagesB/xingcheng/xingcheng.wxml-->
<image src="https://wx.pmc-wz.com/materials/qkh/qkhbt.png" mode="widthFix" class="qkhbt" />
<view class="info">
  <text class="infoname">尊敬的：{{jbinfo.name}} 先生/女士</text>
  <text class="topinfo" wx:for="{{topinfo}}" wx:for-item="item" wx:key="id">{{item}}</text>
</view>
<view class="youRoute">
  <text class="xcCap">您的行程安排如下</text>
  <text class="xcCapY">Your Ltinerary</text>
  <view wx:for="{{jbxc}}" wx:for-item="item" wx:key="id">
    <view class="xctitle">{{item.typeid==1?"来程·":"回程·"}}{{item.title}}</view>
    <view class="xcmain">
      <view class="lcbox">
        <image src="https://wx.pmc-wz.com/materials/qkh/lcicon.png" mode="widthFix" class="lcicon" wx:if="{{item.cateid==1}}" />
        <image src="https://wx.pmc-wz.com/materials/qkh/hb2.png" mode="widthFix" class="lcicon" wx:if="{{item.cateid==2}}" />
        <image src="https://wx.pmc-wz.com/materials/qkh/zzout.png" mode="widthFix" class="lcicon" wx:if="{{item.cateid==3}}" />
        <text class="startTime" wx:if="{{item.cateid!==3}}">{{item.starttime}}</text>
        <text class="startdata" wx:if="{{item.cateid!==3}}">{{item.startdate}}</text>
        <text class="startdd" wx:if="{{item.cateid!==3}}">{{item.start}}</text>
      </view>
      <view class="liechebox" wx:if="{{item.cateid==1}}">
        <view class="lcleft"></view>
        <image src="https://wx.pmc-wz.com/materials/qkh/lieche.png" mode="widthFix" class="lieche"/>
        <view class="lcRight"></view>
        <text class="flycode">{{item.flycode}}</text>
      </view>
      <view class="liechebox" wx:if="{{item.cateid==2}}">
        <view class="lcleft"></view>
        <image src="https://wx.pmc-wz.com/materials/qkh/fx.png" mode="widthFix" class="fjtb"/>
        <view class="lcRight"></view>
        <text class="flycode">{{item.flycode}}</text>
      </view>
      <view class="liechebox2" wx:if="{{item.typeid==3}}">
        <image src="https://wx.pmc-wz.com/materials/qkh/zzcap.png" mode="widthFix" class="zzcap"/>
        <image src="https://wx.pmc-wz.com/materials/qkh/xcright.png" mode="widthFix" class="zzright"/>
      </view>
      <view class="dzbox">
        <image src="https://wx.pmc-wz.com/materials/qkh/dzicon.png" mode="widthFix" class="dzicon" wx:if="{{item.cateid==1}}" />
        <image src="https://wx.pmc-wz.com/materials/qkh/hb.png" mode="widthFix" class="lcicon" wx:if="{{item.cateid==2}}" />
        <image src="https://wx.pmc-wz.com/materials/qkh/zzav.png" mode="widthFix" class="lcicon" wx:if="{{item.cateid==3}}" />
        <text class="startTime" wx:if="{{item.typeid!==3}}">{{item.endtime}}</text>
        <text class="startdata" wx:if="{{item.typeid!==3}}">{{item.enddate}}</text>
        <text class="startdd" wx:if="{{item.typeid!==3}}">{{item.end}}</text>
      </view>
      <view class="xcmemo" wx:if="{{item.typeid!==3 && item.memo}}">提示：{{item.memo}}</view>
    </view>
  </view>
</view>

