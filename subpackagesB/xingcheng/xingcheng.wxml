<view class="dhzyinfoBox">
  <image src="https://wx.pmc-wz.com/materials/tqtx.png" mode="widthFix" class="jiejibanner" />
  <view class="dhzymain">
    <view wx:for="{{tq}}" wx:for-item="item" wx:key="id" class="jbycitem">
      <text class="tqrq">{{item.startdate}}</text>
      <text class="tqline">气温：{{item.qiwen}}</text>
      <text class="tqline">穿衣指数：{{item.chuanyi}}</text>
      <text class="tqline">注意事项：{{item.memo}}</text>
