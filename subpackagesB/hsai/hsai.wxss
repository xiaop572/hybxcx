page{
  padding-bottom: 0 !important;
}
.hsai-container {
  width: 100%;
  height: 100vh;
  position: fixed;
  top: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 132rpx;
  overflow-y: auto;
  scroll-behavior: smooth;
  height: 100vh;
  box-sizing: border-box;
}

.message-wrapper {
  margin-bottom: 20rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.message {
  max-width: 96%;
  padding: 20rpx;
  border-radius: 20rpx;
  word-wrap: break-word;
}

.message-ai cell {
  display: block;
  width: 100%;
  margin: 20rpx 0 0;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.5;
}

.cell-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.contact-tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666666;
}

.message-user {
  margin-left: auto;
  background-color: #007AFF;
  color: #fff;
}

.message-ai {
  margin-right: auto;
  background-color: #ffffff;
  color: #333333;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.message-content {
  font-size: 28rpx;
  line-height: 1.5;
  display: block;
  width: 100%;
}

.thinking-dots {
  display: inline-block;
}

.thinking-dots::after {
  content: '...';
  display: inline-block;
  animation: thinking 1.5s infinite;
  letter-spacing: 2rpx;
}

@keyframes thinking {
  0% { content: '.'; }
  33% { content: '..'; }
  66% { content: '...'; }
  100% { content: '.'; }
}

.disclaimer-text {
  padding: 20rpx;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.message-image {
  max-width: 100%;
  border-radius: 10rpx;
}

.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 10rpx 20rpx;
}

.message-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  background-color: transparent;
}

.action-buttons {
  display: flex;
  align-items: center;
}

.upload-button {
  padding: 0 20rpx;
}

.upload-icon {
  width: 48rpx;
  height: 48rpx;
}

.send-button {
  padding: 10rpx 30rpx;
  background-color: #007AFF;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.disclaimer {
  padding: 20rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
  text-align: justify;
  line-height: 1.4;
}
