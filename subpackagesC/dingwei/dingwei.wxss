/* subpackagesC/dingwei/dingwei.wxss */

/* 定位打卡 */
.location-section {
  margin-top: 20rpx;
}

.location-btn {
  width: 100%;
  background-color: #f7f7f7;
  color: #333;
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  padding: 25rpx 0;
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.location-requirement {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.view-range {
  color: #4CAF50;
  text-decoration: underline;
}

.current-location {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 15rpx;
  padding: 10rpx 0;
  line-height: 1.6;
}

.distance-info {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.distance-status {
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 500;
}

.distance-status.in-range {
  background-color: #e8f5e9; /* 浅绿色背景 */
  color: #4CAF50; /* 绿色文字 */
  border: 1rpx solid #c8e6c9;
}

.distance-status.out-of-range {
  background-color: #ffebee; /* 浅红色背景 */
  color: #f44336; /* 红色文字 */
  border: 1rpx solid #ffcdd2;
}


/* 页面容器 */
.container1 {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部蓝色背景区域 */
.header-section {
  position: relative;
  background: linear-gradient(135deg, #2196F3 0%, #42A5F5 100%);
  height: 300rpx;
  overflow: hidden;
}

/* 背景装饰圆形 */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.bg-circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.bg-circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  left: -30rpx;
  background: rgba(255, 255, 255, 0.05);
}

/* 活动信息容器 */
.activity-info {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  color: white;
}

/* 活动图标 */
.activity-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.activity-icon .icon {
  width: 50rpx;
  height: 50rpx;
}

/* 活动详情 */
.activity-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.activity-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  line-height: 1.2;
}

.activity-time {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 转发按钮 */
.share-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: white;
}

.share-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

/* 签到信息卡片 */
.checkin-card {
  background: white;
  margin: -80rpx 40rpx 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 5;
}

/* 卡片标题 */
.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 签到详情列表 */
.checkin-details {
  margin-bottom: 40rpx;
}

/* 详情项 */
.detail-item {
  display: flex;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.detail-item:last-child {
  margin-bottom: 0;
}

/* 标签样式 */
.detail-item .label {
  color: #666;
  font-size: 30rpx;
  min-width: 160rpx;
  flex-shrink: 0;
}

/* 值样式 */
.detail-item .value {
  color: #333;
  font-size: 30rpx;
  flex: 1;
}

/* 活动描述 */
.activity-description {
  text-align: center;
  padding: 30rpx 0;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 20rpx;
}

.activity-description text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 定位签到功能区域 */
.checkin-form {
  background: white;
  margin: 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 表单区块 */
.form-section {
  margin-bottom: 60rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.required-mark {
  color: #ff4444;
  font-size: 32rpx;
  margin-right: 8rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-right: 8rpx;
}

.section-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 姓名选择器 */
.name-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
}

.placeholder-text {
  color: #999;
  font-size: 30rpx;
}

.selected-text {
  color: #333;
  font-size: 30rpx;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 输入框容器 */
.input-container {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
  overflow: hidden;
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

/* 表单输入框 */
.form-input {
  padding: 0 30rpx;
  font-size: 30rpx;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  display: block;
}

.form-input::placeholder {
  color: #999;
}

/* 输入框聚焦状态 */
.input-container:focus-within {
  border-color: #2196F3;
  background: #fff;
}

/* 自动填写提示 */
.auto-fill-tip {
  font-size: 24rpx;
  color: #2196F3;
  margin-left: 16rpx;
}





/* 提交按钮区域 */
.submit-area {
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.submit-btn.disabled {
  background: #cccccc;
  box-shadow: none;
}

/* 姓名选择弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  transition: padding-bottom 0.3s ease;
}

.modal-container {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.name-modal {
  width: 100%;
  max-height: 70vh;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: modalShow 0.3s ease-out;
  position: relative;
}

@keyframes modalShow {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 搜索框样式 */
.search-container {
  padding: 30rpx 40rpx;
}

.search-box {
  position: relative;
  background: #f8f8f8;
  border-radius: 50rpx;
  padding: 20rpx 60rpx 20rpx 80rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  position: absolute;
  left: 30rpx;
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
}

.search-input::placeholder {
  color: #999;
}

/* 姓名列表样式 */
.name-list {
  max-height: 400rpx;
  overflow-y: auto;
  padding: 0 40rpx;
  min-height: 100rpx;
}

.name-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.name-item:last-child {
  border-bottom: none;
}

.name-radio {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 24rpx;
  position: relative;
}

.name-radio.selected {
  border-color: #2196F3;
  background: #2196F3;
}

.name-radio.selected::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  background: white;
  border-radius: 50%;
}

.name-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

/* 按钮区域样式 */
.modal-buttons {
  display: flex;
  padding: 30rpx 40rpx 40rpx;
  gap: 20rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: #2196F3;
  color: white;
}

.cancel-btn:active {
  background: #e8e8e8;
}

.confirm-btn:active {
  background: #1976D2;
}

/* 调试信息样式 */
.debug-info {
  margin: 30rpx 0;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  border-left: 4rpx solid #2196F3;
}

.debug-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.debug-item {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

/* 右侧浮动按钮样式 */
.floating-btn {
  position: fixed;
  right: 10rpx;
  top: 300rpx;
  width: 120rpx;
  height: 120rpx;
  background: #2196F3;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 20rpx rgba(33, 150, 243, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
  transition: all 0.3s ease;
}

.floating-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.4);
}

.floating-btn-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.floating-btn-text {
  font-size: 20rpx;
  color: white;
  font-weight: 500;
}
