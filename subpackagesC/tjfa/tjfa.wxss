/* 整体页面样式 */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  padding-bottom: 120rpx; /* 为底部操作栏留出空间 */
}

/* 头部样式 */
.header {
  background-color: #1890ff;
  color: white;
  padding: 30rpx 30rpx 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 搜索框样式 */
.search-box {
  background-color: white;
  margin: 20rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #999;
}

/* 项目列表样式 */
.item-list {
  background-color: white;
  margin: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.item-row {
  display: flex;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.item-row:last-child {
  border-bottom: none;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #999;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-price {
  color: #ff6b00;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.item-controls {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 1rpx solid #ddd;
  border-radius: 6rpx;
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f0f0f0;
}

.checkbox::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 12rpx;
  border: 4rpx solid #cccccc;
  border-top: none;
  border-right: none;
  transform: translate(-50%, -60%) rotate(-45deg);
}

.checkbox.checked {
  background-color: #1890ff;
  border-color: #1890ff;
}

.checkbox.checked::after {
  border-color: #fff;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 12rpx;
  border: 4rpx solid #fff;
  border-top: none;
  border-right: none;
  transform: translate(-50%, -60%) rotate(-45deg);
}

/* 底部操作栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.cart-section {
  display: flex;
  align-items: center;
  flex: 1;
}

.cart-icon {
  width: 60rpx;
  height: 60rpx;
  position: relative;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #ff4d4f;
  color: white;
  font-size: 20rpx;
  border-radius: 20rpx;
  padding: 2rpx 10rpx;
  min-width: 30rpx;
  text-align: center;
}

.total-price {
  margin-left: 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b00;
}

.checkout-btn {
  background-color: #1890ff;
  color: white;
  font-size: 32rpx;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
}

/* 原有样式保留并修改 */
.plan-list {
  padding: 20rpx;
}

.plan-card {
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.plan-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.plan-desc {
  font-size: 24rpx;
  color: #999;
}

.plan-item {
  background-color: white;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.plan-header {
  display: flex;
  padding: 30rpx 20rpx;
  align-items: center;
}

.plan-left {
  margin-right: 20rpx;
}

.plan-icon {
  width: 80rpx;
  height: 80rpx;
}

.plan-center {
  flex: 1;
}

.plan-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.plan-right {
  text-align: right;
}

.plan-price {
  color: #ff6b00;
  font-size: 32rpx;
  font-weight: bold;
}

.plan-items {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  background-color: #f9f9f9;
}

.plan-items.expanded {
  max-height: 1000rpx;
}

.plan-item-title {
  padding: 20rpx;
  font-size: 26rpx;
  color: #666;
  border-top: 1rpx solid #f0f0f0;
}

.plan-item-list {
  padding: 0 20rpx 20rpx;
}

.plan-item-row {
  padding: 15rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.plan-item-name {
  font-size: 28rpx;
  color: #333;
}

.plan-footer {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.arrow-btn {
  width: 60rpx;
  height: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.arrow-icon {
  width: 30rpx;
  height: 30rpx;
  transition: transform 0.3s ease;
}

.arrow-icon.expanded {
  transform: rotate(180deg);
}