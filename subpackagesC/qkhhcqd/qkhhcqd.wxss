/* subpackagesC/dingwei/dingwei.wxss */

/* 定位相关样式 */
.location-section {
  margin-top: 20rpx;
}

.location-btn {
  width: 100%;
  background-color: #f7f7f7;
  color: #333;
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  padding: 25rpx 0;
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.location-requirement {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.current-location {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 15rpx;
  padding: 10rpx 0;
  line-height: 1.6;
}

.distance-status {
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 500;
}

.distance-status.in-range {
  background-color: #e8f5e9; /* 浅绿色背景 */
  color: #4CAF50; /* 绿色文字 */
  border: 1rpx solid #c8e6c9;
}

.distance-status.out-of-range {
  background-color: #ffebee; /* 浅红色背景 */
  color: #f44336; /* 红色文字 */
  border: 1rpx solid #ffcdd2;
}

/* 页面容器 */
.container1 {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部蓝色背景区域 */
.header-section {
  position: relative;
  background: linear-gradient(135deg, #2196F3 0%, #42A5F5 100%);
  height: 300rpx;
  overflow: hidden;
}

/* 背景装饰圆形 */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.bg-circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.bg-circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  left: -30rpx;
  background: rgba(255, 255, 255, 0.05);
}

/* 活动信息容器 */
.activity-info {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  color: white;
}

/* 活动图标 */
.activity-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.activity-icon .icon {
  width: 50rpx;
  height: 50rpx;
}

/* 活动详情 */
.activity-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.activity-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  line-height: 1.2;
}

.activity-time {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 转发按钮 */
.share-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: white;
}

.share-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

/* 签到信息卡片 */
.checkin-card {
  background: white;
  margin: -80rpx 40rpx 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 5;
}

/* 卡片标题 */
.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 签到详情列表 */
.checkin-details {
  margin-bottom: 40rpx;
}

/* 详情项 */
.detail-item {
  display: flex;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.detail-item:last-child {
  margin-bottom: 0;
}

/* 标签样式 */
.detail-item .label {
  color: #666;
  font-size: 30rpx;
  min-width: 160rpx;
  flex-shrink: 0;
}

/* 值样式 */
.detail-item .value {
  color: #333;
  font-size: 30rpx;
  flex: 1;
}

/* 活动描述 */
.activity-description {
  text-align: center;
  padding: 30rpx 0;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 20rpx;
}

.activity-description text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 定位签到功能区域 */
.checkin-form {
  background: white;
  margin: 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 表单区块 */
.form-section {
  margin-bottom: 60rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.required-mark {
  color: #ff4444;
  font-size: 32rpx;
  margin-right: 8rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-right: 8rpx;
}

.section-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 姓名选择器 */
.name-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
}

.placeholder-text {
  color: #999;
  font-size: 30rpx;
}

.selected-text {
  color: #333;
  font-size: 30rpx;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 输入框容器 */
.input-container {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
  overflow: hidden;
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

/* 表单输入框 */
.form-input {
  padding: 0 30rpx;
  font-size: 30rpx;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  display: block;
}

.form-input::placeholder {
  color: #999;
}

/* 输入框聚焦状态 */
.input-container:focus-within {
  border-color: #2196F3;
  background: #fff;
}

/* 自动填写提示 */
.auto-fill-tip {
  font-size: 24rpx;
  color: #2196F3;
  margin-left: 16rpx;
}





/* 提交按钮区域 */
.submit-area {
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.submit-btn.disabled {
  background: #cccccc;
  box-shadow: none;
}

/* 姓名选择弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  transition: padding-bottom 0.3s ease;
}

.modal-container {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.name-modal {
  width: 100%;
  max-height: 70vh;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: modalShow 0.3s ease-out;
  position: relative;
}

@keyframes modalShow {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 搜索框样式 */
.search-container {
  padding: 30rpx 40rpx;
}

.search-box {
  position: relative;
  background: #f8f8f8;
  border-radius: 50rpx;
  padding: 20rpx 60rpx 20rpx 80rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  position: absolute;
  left: 30rpx;
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
}

.search-input::placeholder {
  color: #999;
}

/* 姓名列表样式 */
.name-list {
  max-height: 400rpx;
  overflow-y: auto;
  padding: 0 40rpx;
  min-height: 100rpx;
}

.name-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.name-item:last-child {
  border-bottom: none;
}

.name-radio {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 24rpx;
  position: relative;
}

.name-radio.selected {
  border-color: #2196F3;
  background: #2196F3;
}

.name-radio.selected::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  background: white;
  border-radius: 50%;
}

.name-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

/* 按钮区域样式 */
.modal-buttons {
  display: flex;
  padding: 30rpx 40rpx 40rpx;
  gap: 20rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: #2196F3;
  color: white;
}

.cancel-btn:active {
  background: #e8e8e8;
}

.confirm-btn:active {
  background: #1976D2;
}

/* 调试信息样式 */
.debug-info {
  margin: 30rpx 0;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  border-left: 4rpx solid #2196F3;
}

.debug-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.debug-item {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

/* 右侧浮动按钮样式 */
.floating-btn {
  position: fixed;
  right: 10rpx;
  top: 300rpx;
  width: 120rpx;
  height: 120rpx;
  background: #2196F3;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 20rpx rgba(33, 150, 243, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
  transition: all 0.3s ease;
}

.floating-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.4);
}

.floating-btn-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.floating-btn-text {
  font-size: 20rpx;
  color: white;
  font-weight: 500;
}

/* 报到信息浮窗样式 */
.sign-info-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease-out;
  backdrop-filter: blur(4rpx);
}

.sign-info-container {
  width: 90%;
  max-width: 650rpx;
  max-height: 80%;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(1);
  animation: modalShow 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2), 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.sign-info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 30rpx 20rpx;
  background: #2196F3;
  position: relative;
  overflow: hidden;
}

.sign-info-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="20" cy="20" r="2" fill="rgba(255,255,255,0.1)"/><circle cx="80" cy="40" r="1.5" fill="rgba(255,255,255,0.1)"/><circle cx="40" cy="80" r="1" fill="rgba(255,255,255,0.1)"/></svg>');
  pointer-events: none;
}

.sign-info-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

.close-btn {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  padding: 0;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.close-btn:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

.sign-info-content {
  max-height: 700rpx;
  overflow-y: auto;
  background: #ffffff;
}

.loading-container,
.empty-container {
  padding: 80rpx 60rpx;
  text-align: center;
  color: #999;
  font-size: 30rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  margin: 20rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #dee2e6;
}

.loading-container::before,
.empty-container::before {
  content: '📋';
  display: block;
  font-size: 60rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.sign-info-list {
  padding: 30rpx 20rpx 20rpx;
}

.sign-info-item {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #e9ecef;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.sign-info-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: #2196F3;
}

.sign-info-item:last-child {
  margin-bottom: 0;
}

.sign-info-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.sign-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-left: 20rpx;
}

.sign-info-row:last-child {
  margin-bottom: 0;
}

.sign-info-label {
  font-size: 28rpx;
  color: #6c757d;
  min-width: 140rpx;
  font-weight: 600;
  position: relative;
}

.sign-info-label::after {
  content: '';
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 4rpx;
  background: #2196F3;
  border-radius: 50%;
}

.sign-info-value {
  font-size: 30rpx;
  color: #212529;
  flex: 1;
  font-weight: 500;
  line-height: 1.4;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    backdrop-filter: blur(0);
  }
  to {
    opacity: 1;
    backdrop-filter: blur(4rpx);
  }
}

@keyframes modalShow {
  0% {
    transform: scale(0.7) translateY(100rpx);
    opacity: 0;
  }
  50% {
    transform: scale(1.05) translateY(-20rpx);
    opacity: 0.8;
  }
  100% {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
}

/* 滚动条美化 */
.sign-info-content::-webkit-scrollbar {
  width: 6rpx;
}

.sign-info-content::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.05);
  border-radius: 3rpx;
}

.sign-info-content::-webkit-scrollbar-thumb {
  background: #2196F3;
  border-radius: 3rpx;
}

.sign-info-content::-webkit-scrollbar-thumb:hover {
  background: #1976D2;
}

/* ==================== 手写签名样式 ==================== */

/* 签名容器 */
.signature-container {
  width: 100%;
  min-height: 200rpx;
}

/* 签名预览区域 */
.signature-preview {
  width: 100%;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fafafa;
}

.signature-image {
  width: 100%;
  height: 200rpx;
  background: white;
}

.signature-actions {
  padding: 20rpx;
  background: white;
  border-top: 2rpx solid #f0f0f0;
  display: flex;
  justify-content: center;
}

.signature-btn {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.edit-btn {
  background: #2196F3;
  color: white;
}

.edit-btn:active {
  background: #1976D2;
}

/* 签名占位区域 */
.signature-placeholder {
  width: 100%;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.signature-placeholder:active {
  background: #f0f0f0;
}

.signature-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.signature-text {
  font-size: 28rpx;
  color: #999;
}

/* 签名弹窗遮罩 */
.signature-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease-out;
}

/* 签名弹窗 */
.signature-modal {
  width: 90%;
  max-width: 700rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
  animation: modalShow 0.3s ease-out;
}

/* 签名弹窗头部 */
.signature-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  background: linear-gradient(135deg, #2196F3 0%, #42A5F5 100%);
  color: white;
}

.signature-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
}

.signature-close-btn {
  width: 60rpx !important;
  height: 60rpx;
  min-width: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border: none;
  border-radius: 50%;
  color: white;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 1;
  flex-shrink: 0;
}

.signature-close-btn::after {
  border: none;
}

.signature-close-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

/* 签名画布容器 */
.signature-canvas-container {
  position: relative;
  margin: 40rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: white;
  overflow: hidden;
}

/* 签名画布 */
.signature-canvas {
  width: 100%;
  height: 400rpx;
  background: white;
  display: block;
}

/* 签名提示文字 */
.signature-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 32rpx;
  color: #ccc;
  pointer-events: none;
  user-select: none;
}

/* 签名弹窗按钮区域 */
.signature-modal-buttons {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 40rpx;
}

.signature-modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.signature-modal-btn::after {
  border: none;
}

.clear-btn {
  background: #f5f5f5;
  color: #666;
}

.clear-btn:active {
  background: #e8e8e8;
}

.save-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.save-btn:active {
  background: linear-gradient(135deg, #45a049 0%, #4CAF50 100%);
}

.save-btn[disabled] {
  background: #cccccc;
  box-shadow: none;
  color: #999;
}