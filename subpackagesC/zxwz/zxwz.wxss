page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 0 30rpx;
}

.header {
  padding: 30rpx 0;
  text-align: center;
  width: 100%;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  text-align: center;
  padding: 0 30rpx;
  display: block;
}

.loading {
  text-align: center;
  line-height: 200rpx;
  height: 200rpx;
  color: #999;
}

.category-title {
  margin: 30rpx 0 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  width: 100%;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.category-desc {
  font-size: 24rpx;
  color: #666;
  font-weight: normal;
  margin-top: 6rpx;
  display: block;
}

.question-card {
  width: 100%;
  box-sizing: border-box;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.question-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 30rpx;
  font-weight: 500;
}

.options-list {
  width: 100%;
}

.options-list > .option-item {
  margin-bottom: 20rpx;
}

.option-item {
  padding: 10rpx 0;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 1rpx solid #ddd;
  border-radius: 6rpx;
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.checkbox.checked {
  background-color: #0e71ce;
  border-color: #0e71ce;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 12rpx;
  border: 4rpx solid #fff;
  border-top: none;
  border-right: none;
  transform: translate(-50%, -60%) rotate(-45deg);
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.footer {
  margin: 40rpx 0;
  overflow: hidden;
  text-align: center;
}

.prev-btn, .submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.prev-btn {
  background-color: #f5f5f5;
  color: #666;
  border: 1rpx solid #ddd;
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
}

.submit-btn {
  background-color: #0e71ce;
  color: #fff;
  display: inline-block;
  width: 200rpx;
}