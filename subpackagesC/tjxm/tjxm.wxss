page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif;
}

.tjxm-wrapper {
  width: 100%;
  height: 100vh;
  position: relative;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.header {
  width: 100%;
  height: 88rpx;
  background-color: #fff;
  position: relative;
  text-align: center;
  line-height: 88rpx;
  border-bottom: 1rpx solid #eee;
}

.back-icon {
  position: absolute;
  left: 30rpx;
  top: 0;
  font-size: 36rpx;
  color: #333;
}

.header-title {
  font-size: 34rpx;
  color: #333;
  font-weight: 500;
}

.header-icons {
  position: absolute;
  right: 30rpx;
  top: 0;
  height: 88rpx;
  line-height: 88rpx;
}

.icon-dot, .icon-line, .icon-circle {
  float: left;
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 搜索框 */
.search-box {
  width: 85%;
  height: 70rpx;
  background-color: #fff;
  margin: 20rpx auto;
  border-radius: 35rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.search-box:active {
  transform: scale(0.98);
}

.search-icon {
  position: absolute;
  left: 20rpx;
  font-size: 36rpx;
  color: #1f83ff;
}

.search-input {
  width: 65%;
  height: 70rpx;
  line-height: 70rpx;
  padding-left: 70rpx;
  font-size: 26rpx;
  color: #333;
}

.add-icon {
  position: absolute;
  right: 0;
  top: 0;
  width: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  font-size: 36rpx;
  color: #fff;
  background-color: #1f83ff;
  border-radius: 0 35rpx 35rpx 0;
  box-shadow: -2rpx 0 8rpx rgba(31, 131, 255, 0.2);
}

/* 重点建议提示 */
.recommend-tip {
  width: 85%;
  margin: 25rpx auto;
  background-color: #1f83ff;
  border-radius: 12rpx;
  padding: 20rpx;
  overflow: hidden;
  color: #fff;
  box-shadow: 0 4rpx 15rpx rgba(31, 131, 255, 0.2);
  display: flex;
  align-items: center;
}

.tip-icon {
  width: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  font-size: 38rpx;
  margin-right: 15rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.tip-subtitle {
  font-size: 24rpx;
  line-height: 34rpx;
  opacity: 0.9;
  margin-top: 5rpx;
}

/* 主体内容区 */
.main-content {
  position: absolute;
  top: 240rpx;
  bottom: 120rpx;
  left: 0;
  right: 0;
  overflow: hidden;
  background-color: #f5f5f5;
}

/* 左侧分类导航 */
.category-nav {
  width: 180rpx;
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  background-color: #f8f8f8;
  overflow-y: auto;
}

.nav-item {
  width: 180rpx;
  height: 160rpx;
  text-align: center;
  position: relative;
  padding: 20rpx 0;
  box-sizing: border-box;
  border-bottom: 1rpx solid #eee;
}

.nav-item.active {
  background-color: #fff;
  border-left: 4rpx solid #1f83ff;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #666;
  line-height: 34rpx;
  padding: 0 10rpx;
}

.badge {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  text-align: center;
  background-color: #ff5a5f;
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
}

/* 右侧项目列表 */
.item-list {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 180rpx;
  right: 0;
  overflow-y: auto;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #f5f5f5;
}

.exam-item {
  width: 100%;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.exam-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.item-header {
  overflow: hidden;
  margin-bottom: 10rpx;
}

.item-name {
  float: left;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  width: 70%;
}

.item-tag, .item-recommend {
  float: left;
  font-size: 20rpx;
  color: #ff5a5f;
  background-color: #fff1f0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-left: 10rpx;
  margin-top: 4rpx;
}

.item-recommend {
  background-color: #fff1f0;
}

.item-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 34rpx;
  margin: 10rpx 0;
}

.item-price {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: inline-block;
}

.item-check {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
}

.item-check.selected {
  background-color: #1f83ff;
  border-color: #1f83ff;
}

.item-check.selected:after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 10rpx;
  border: 4rpx solid #fff;
  border-top: none;
  border-right: none;
  transform: translate(-50%, -60%) rotate(-45deg);
}

/* 底部结算栏 */
.footer {
  width: 100%;
  height: 120rpx;
  background-color: #fff;
  position: fixed;
  left: 0;
  bottom: 0;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 999;
}

.cart {
  position: absolute;
  left: 30rpx;
  top: 30rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
}

.cart-badge {
  position: absolute;
  right: -10rpx;
  top: -10rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background-color: #ff5a5f;
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
}

.total-price {
  position: absolute;
  left: 100rpx;
  top: 0;
  height: 120rpx;
  line-height: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.price {
  font-weight: 500;
  font-size: 32rpx;
}

.btn-cancel {
  position: absolute;
  right: 180rpx;
  top: 0;
  width: 180rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  font-size: 28rpx;
  background-color: #f8f8f8;
  color: #666;
}

.btn-confirm {
  position: absolute;
  right: 0;
  top: 0;
  width: 180rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  font-size: 28rpx;
  background-color: #1f83ff;
  color: #fff;
}