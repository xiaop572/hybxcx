/* subpackages/tsal/tsal.wxss */
page {
  height: 100%;
  background-color: #fff;
}

.container {
  height: 100%;
  padding: 0 30rpx;
  box-sizing: border-box;
}

/* 顶部导航栏样式 */
.nav-container {
  display: flex;
  align-items: center;
  position: relative;
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.nav-bar {
  white-space: nowrap;
  padding: 0;
  flex: 1;
  overflow: hidden;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  
}

.nav-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  z-index: 10;
}

.nav-arrow .arrow-icon {
  color: #999;
  font-size: 32rpx;
  font-weight: normal;
}

.nav-item {
  display: inline-block;
  color: #666;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  position: relative;
  transition: all 0.3s ease;
  border-radius: 50rpx;
  margin: 0 12rpx;
  box-shadow: 0 0 20rpx 0 rgba(135, 206, 250,0.3);
  text-align: center;
  vertical-align: middle;
  margin-top: 5rpx;
}

.nav-item.active {
  color: #fff;
  font-weight: normal;
  background-color: #007AFF;
  transform: none;
}

.nav-item.active::after {
  display: none;
}

/* 案例展示区域样式 */
.case-container {
  padding: 20rpx 0;
}

.case-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.case-item {
  width: 48%;
  margin-bottom: 30rpx;
  overflow: hidden;
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
  border: 1px solid #f0f0f0;
}

.case-item:active {
  transform: scale(0.98);
}

.case-image {
  width: 100%;
  height: 280rpx;
  background-color: #f8f8f8;
  border-radius: 20rpx;
}

.case-desc {
  color: #333;
  font-size: 26rpx;
  padding: 20rpx 15rpx;
  text-align: center;
  line-height: 1.4;
  background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%);
}