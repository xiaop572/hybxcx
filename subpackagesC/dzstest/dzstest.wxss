page{
  padding-bottom: 0 !important;
}
/* 电子书容器 */
.ebook-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

/* 加载状态 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  text-align: center;
  color: #333;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(51, 51, 51, 0.3);
  border-top: 4rpx solid #333;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #333;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 单页电子书容器 */
.single-page-wrapper {
  width: 100%;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  perspective: 2200px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  overflow: hidden;
}

/* 页面容器 */
.page-container {
  position: relative;
  width: 90%;
  max-width: 400px;
  height: 85%;
  transform-style: preserve-3d;
  overflow: hidden;
}

/* 当前页面 */
.current-page {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transform-origin: left center;
  transform-style: preserve-3d;
  backface-visibility: hidden;
  transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  z-index: 2;
}

.next-page {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transform-origin: left center;
  transform-style: preserve-3d;
  backface-visibility: hidden;
  transform: rotateY(180deg);
  z-index: 1;
}

.prev-page {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transform-origin: left center;
  transform-style: preserve-3d;
  backface-visibility: hidden;
  transform: rotateY(-180deg);
  z-index: 1;
}

/* 下一页预览 - 已移除 */

/* 上一页预览 - 已移除 */

/* 页面内容 - 云展网风格 */
.page-content {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  background: #ffffff;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  border-radius: 8px;
  overflow: visible;
  backface-visibility: hidden;
  transform-style: preserve-3d;
  transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  z-index: 10;
  
  /* 页面卷曲效果 */
  background-image: 
    linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.1) 25%, transparent 50%),
    linear-gradient(to right, #ffffff 0%, #fafafa 100%);
  background-size: 100% 100%, 100% 100%;
}

/* 纸张纹理效果 */
.page-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 20% 20%, rgba(0,0,0,0.02) 1px, transparent 1px),
    radial-gradient(circle at 80% 80%, rgba(0,0,0,0.02) 1px, transparent 1px);
  background-size: 20px 20px, 30px 30px;
  pointer-events: none;
  z-index: 1;
  border-radius: 8px;
  transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* 翻页时纸张纹理变化 */
.page-content.flipping-next::before,
.page-content.flipping-prev::before {
  background: 
    radial-gradient(circle at 30% 30%, rgba(0,0,0,0.05) 1px, transparent 1px),
    radial-gradient(circle at 70% 70%, rgba(0,0,0,0.05) 1px, transparent 1px),
    linear-gradient(45deg, rgba(255,255,255,0.1) 0%, transparent 50%);
  background-size: 15px 15px, 25px 25px, 100% 100%;
}

/* 书本卷角效果 */
.page-content::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40px;
  height: 40px;
  background: linear-gradient(
    225deg,
    rgba(255, 255, 255, 0.8) 0%,
    rgba(240, 240, 240, 0.6) 25%,
    rgba(220, 220, 220, 0.4) 50%,
    rgba(200, 200, 200, 0.3) 75%,
    transparent 100%
  );
  border-radius: 40px 0 8px 0;
  box-shadow: 
    inset -2px -2px 4px rgba(0, 0, 0, 0.1),
    inset 1px 1px 2px rgba(255, 255, 255, 0.3),
    -2px -2px 8px rgba(0, 0, 0, 0.15);
  z-index: 12;
  transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* 翻页时卷角效果增强 */
.page-content.flipping-next::after,
.page-content.flipping-prev::after {
  transform: scale(1.2) rotate(5deg);
  box-shadow: 
    inset -3px -3px 6px rgba(0, 0, 0, 0.2),
    inset 2px 2px 4px rgba(255, 255, 255, 0.4),
    -4px -4px 12px rgba(0, 0, 0, 0.25);
}

/* 页面图片 - 云展网风格 */
.page-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 8px;
}

/* 页面编号 - 云展网风格 */
.page-number {
  position: absolute;
  bottom: 20px;
  right: 20px;
  background: rgba(0, 0, 0, 0.7);
  color: white;
  padding: 8px 12px;
  border-radius: 20px;
  font-size: 14px;
  backdrop-filter: blur(10px);
  z-index: 15;
}

/* 卷角拖拽区域 */
.corner-drag-area {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 80px;
  height: 80px;
  z-index: 20;
  cursor: pointer;
  transform-origin: bottom right;
  transition: transform 0.1s ease-out;
  transform-style: preserve-3d;
}

/* 卷角折叠效果 */
.corner-fold {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 50px;
  height: 50px;
  background: linear-gradient(
    -45deg,
    rgba(255, 255, 255, 0.9) 0%,
    rgba(240, 240, 240, 0.8) 25%,
    rgba(200, 200, 200, 0.6) 50%,
    rgba(150, 150, 150, 0.4) 75%,
    rgba(100, 100, 100, 0.3) 100%
  );
  border-radius: 0 8px 0 0;
  transform-origin: bottom right;
  transform-style: preserve-3d;
  box-shadow: 
    -4px -4px 12px rgba(0, 0, 0, 0.25),
    -2px -2px 6px rgba(0, 0, 0, 0.15),
    inset 2px 2px 4px rgba(255, 255, 255, 0.7),
    inset -1px -1px 2px rgba(0, 0, 0, 0.1);
  transition: all 0.15s ease-out;
  border: 1px solid rgba(0, 0, 0, 0.1);
}

/* 卷角拖拽状态 */
.corner-drag-area.dragging {
  z-index: 25;
}

.corner-drag-area.dragging .corner-fold {
  background: linear-gradient(
    -45deg,
    rgba(255, 255, 255, 0.95) 0%,
    rgba(245, 245, 245, 0.85) 20%,
    rgba(220, 220, 220, 0.7) 40%,
    rgba(180, 180, 180, 0.5) 60%,
    rgba(140, 140, 140, 0.4) 80%,
    rgba(100, 100, 100, 0.35) 100%
  );
  box-shadow: 
    -8px -8px 20px rgba(0, 0, 0, 0.35),
    -4px -4px 10px rgba(0, 0, 0, 0.25),
    -2px -2px 5px rgba(0, 0, 0, 0.15),
    inset 3px 3px 6px rgba(255, 255, 255, 0.8),
    inset -2px -2px 4px rgba(0, 0, 0, 0.15);
  border: 1px solid rgba(0, 0, 0, 0.15);
}

/* 卷角悬停效果 */
.corner-drag-area:hover .corner-fold {
  background: linear-gradient(
    -45deg,
    rgba(255, 255, 255, 0.92) 0%,
    rgba(242, 242, 242, 0.82) 25%,
    rgba(210, 210, 210, 0.65) 50%,
    rgba(170, 170, 170, 0.45) 75%,
    rgba(120, 120, 120, 0.32) 100%
  );
  box-shadow: 
    -5px -5px 15px rgba(0, 0, 0, 0.3),
    -3px -3px 8px rgba(0, 0, 0, 0.2),
    inset 2.5px 2.5px 5px rgba(255, 255, 255, 0.75),
    inset -1.5px -1.5px 3px rgba(0, 0, 0, 0.12);
  transform: scale(1.05);
}

/* 移除翻页效果层 */

/* 页面背面效果 - 已移除 */

/* 触摸区域 */
.touch-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 20;
  background: transparent;
}

/* 翻页动画关键帧 - 页面卷曲效果 */
@keyframes flipNext {
  0% {
    transform: rotateY(0deg) rotateX(0deg);
    transform-origin: left center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }
  25% {
    transform: rotateY(-15deg) rotateX(5deg) translateZ(20px);
    transform-origin: left center;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
  }
  50% {
    transform: rotateY(-90deg) rotateX(10deg) translateZ(40px);
    transform-origin: left center;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
  75% {
    transform: rotateY(-165deg) rotateX(5deg) translateZ(20px);
    transform-origin: left center;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
  }
  100% {
    transform: rotateY(-180deg) rotateX(0deg);
    transform-origin: left center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }
}

@keyframes flipPrev {
  0% {
    transform: rotateY(0deg) rotateX(0deg);
    transform-origin: right center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }
  25% {
    transform: rotateY(15deg) rotateX(5deg) translateZ(20px);
    transform-origin: right center;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
  }
  50% {
    transform: rotateY(90deg) rotateX(10deg) translateZ(40px);
    transform-origin: right center;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
  75% {
    transform: rotateY(165deg) rotateX(5deg) translateZ(20px);
    transform-origin: right center;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
  }
  100% {
    transform: rotateY(180deg) rotateX(0deg);
    transform-origin: right center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }
}

@keyframes slideInNext {
  0% {
    transform: rotateY(180deg) rotateX(0deg) translateZ(-20px);
    transform-origin: left center;
    opacity: 0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }
  25% {
    transform: rotateY(165deg) rotateX(-5deg) translateZ(0px);
    transform-origin: left center;
    opacity: 0.3;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
  }
  50% {
    transform: rotateY(90deg) rotateX(-10deg) translateZ(20px);
    transform-origin: left center;
    opacity: 0.6;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
  75% {
    transform: rotateY(15deg) rotateX(-5deg) translateZ(10px);
    transform-origin: left center;
    opacity: 0.8;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
  }
  100% {
    transform: rotateY(0deg) rotateX(0deg) translateZ(0px);
    transform-origin: left center;
    opacity: 1;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }
}

@keyframes slideInPrev {
  0% {
    transform: rotateY(-180deg) rotateX(0deg) translateZ(-20px);
    transform-origin: right center;
    opacity: 0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }
  25% {
    transform: rotateY(-165deg) rotateX(-5deg) translateZ(0px);
    transform-origin: right center;
    opacity: 0.3;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
  }
  50% {
    transform: rotateY(-90deg) rotateX(-10deg) translateZ(20px);
    transform-origin: right center;
    opacity: 0.6;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
  75% {
    transform: rotateY(-15deg) rotateX(-5deg) translateZ(10px);
    transform-origin: right center;
    opacity: 0.8;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
  }
  100% {
    transform: rotateY(0deg) rotateX(0deg) translateZ(0px);
    transform-origin: right center;
    opacity: 1;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }
}

/* 页面卷曲变形动画 */
@keyframes pageCurl {
  0% {
    transform: rotateY(0deg) rotateX(0deg) skewY(0deg);
    border-radius: 8px;
  }
  30% {
    transform: rotateY(-30deg) rotateX(8deg) skewY(2deg);
    border-radius: 8px 20px 8px 8px;
  }
  60% {
    transform: rotateY(-60deg) rotateX(15deg) skewY(5deg);
    border-radius: 8px 30px 8px 8px;
  }
  100% {
    transform: rotateY(-90deg) rotateX(20deg) skewY(8deg);
    border-radius: 8px 40px 8px 8px;
  }
}

/* 翻页状态类 */
.flipping-next {
  animation: flipNext 1.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

.flipping-prev {
  animation: flipPrev 1.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

.sliding-in-next {
  animation: slideInNext 1.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

.sliding-in-prev {
  animation: slideInPrev 1.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

/* 翻页状态样式 */
.page-content.flipping-next {
  animation: flipNext 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards,
             pageCurl 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  transform-origin: left center;
}

.page-content.flipping-prev {
  animation: flipPrev 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards,
             pageCurl 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  transform-origin: right center;
}

.page-content.sliding-in-next {
  animation: slideInNext 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  transform-origin: left center;
}

.page-content.sliding-in-prev {
  animation: slideInPrev 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  transform-origin: right center;
}

/* 翻页时的页面变形效果 */
.page-content.flipping-next,
.page-content.flipping-prev {
  background-image: 
    linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.3) 25%, rgba(0,0,0,0.1) 50%, transparent 75%),
    linear-gradient(to right, #ffffff 0%, #f5f5f5 50%, #ffffff 100%);
  box-shadow: 
    0 20px 60px rgba(0, 0, 0, 0.3),
    inset 0 0 20px rgba(0, 0, 0, 0.1),
    inset 0 0 40px rgba(255, 255, 255, 0.5);
}

/* 翻页效果层 */
.flip-effect {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 15;
  transform-style: preserve-3d;
}

/* 翻页阴影和高光效果已删除 */



/* 页面指示器 */
.page-indicator {
  position: absolute;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 300;
}

.indicator-content {
  background: rgba(0, 0, 0, 0.7);
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(8px);
  text-align: center;
}

.page-info {
  font-size: 26rpx;
  color: #d4af37;
  margin-bottom: 8rpx;
  display: block;
}

.progress-bar {
  width: 200rpx;
  height: 6rpx;
  background: rgba(212, 175, 55, 0.3);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(to right, #d4af37, #ffd700);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* 控制按钮 */
.control-buttons {
  position: absolute;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 40rpx;
  z-index: 300;
}

.control-btn {
  background: rgba(0, 0, 0, 0.7);
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s ease;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.control-btn:active {
  transform: scale(0.95);
  background: rgba(212, 175, 55, 0.2);
}

.btn-icon {
  font-size: 32rpx;
  color: #d4af37;
  font-weight: bold;
}

.btn-text {
  font-size: 24rpx;
  color: #d4af37;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .single-page-wrapper {
    padding: 20rpx;
  }
  
  .page-container {
    width: 95vw;
    height: 75vh;
    max-width: 600rpx;
    max-height: 800rpx;
  }
  
  .page-number {
    font-size: 20rpx;
    bottom: 15rpx;
    padding: 6rpx 12rpx;
  }
  
  .control-btn {
    padding: 12rpx 20rpx;
  }
  
  .btn-text {
    font-size: 22rpx;
  }
  
  .page-info {
    font-size: 24rpx;
  }
  
  .progress-bar {
    width: 160rpx;
  }
}