/* subpackagesC/yhq/yhq.wxss */
page {
  background-color: #f5f5f5;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 标签栏样式 */
.tab-bar {
  display: flex;
  padding: 24rpx 24rpx 0;
  margin-bottom: 24rpx;
  justify-content: center;
}

.tab-item {
  background-color: #f8f8f8;
  border-radius: 40rpx;
  padding: 5rpx 40rpx;
  margin-right: 16rpx;
  text-align: center;
}

.tab-item:last-child {
  margin-right: 0;
}

.tab-item text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.tab-item.active {
  background-color: #007AFF;
}

.tab-item.active text {
  color: #fff;
  font-weight: 600;
}

/* 优惠券列表 */
.coupon-list {
  flex: 1;
}

/* 优惠券卡片 */
.coupon-item {
  width: 90%;
  margin: auto;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.coupon-card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
  padding: 0 30rpx;
}
.coupon-top{
  display: flex;
  margin-top: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 15rpx;
}
/* 优惠券左侧价格区域 */
.coupon-left {
  width: 120rpx;
  background: #fff;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}




.amount-number {
  font-size: 60rpx;
  color: #007AFF;
  font-weight: 700;
  line-height: 1;
}

.amount-unit {
  font-size: 28rpx;
  color: #007AFF;
  font-weight: 500;
  margin-left: 4rpx;
}

.coupon-type {
  font-size: 22rpx;
  color: #007AFF;
  text-align: center;
  display: block;
}

/* 优惠券右侧内容区域 */
.coupon-right {
  flex: 1;
  padding: 10rpx 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.coupon-info {
  flex: 1;
}

.coupon-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
  line-height: 1.3;
}

.coupon-condition {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

/* 分割线样式 */
.coupon-divider {
  height: 2rpx;
  background-color: #e0e0e0;
  margin: 16rpx 0;
}

.coupon-action {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin:20rpx 0;
}

.use-button {
  background-color: #FF3B30;
  color: #fff;
  padding: 5rpx 15rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
  min-width: 80rpx;
}

.used-status {
  color: #999;
  font-size: 24rpx;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

/* 已过期优惠券样式 */
.coupon-item.expired {
  opacity: 0.6;
}


.coupon-item.expired .coupon-title,
.coupon-item.expired .coupon-condition {
  color: #999;
}

.expired-status {
  color: #999;
  font-size: 24rpx;
  background: #f0f0f0;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

/* 已使用优惠券样式 */
.coupon-item.used .coupon-card {
  opacity: 0.6;
}

.used-left {
  background: linear-gradient(135deg, #999 0%, #666 100%) !important;
}

.coupon-item.used .coupon-title,
.coupon-item.used .coupon-condition {
  color: #999;
}



/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 点击效果 */
.tab-item:active {
  opacity: 0.8;
}

.use-button:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.coupon-card:active {
  transform: scale(0.98);
}