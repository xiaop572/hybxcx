<!--pages/jiesuan/jiesuan.wxml-->

<view class="tlxr">
  <view class="tishi">
    <text>购买默认为实名姓名，也可修改</text>
  </view>
  <view class="informmation">
    <label for="js_input1" class="weui-cell weui-cell_active">
      <view class="weui-cell__hd"><text class="weui-label">患者姓名</text></view>
      <view class="weui-cell__bd">
        <input id="js_input1" class="weui-input" placeholder="填写本人姓名" model:value="{{name}}" />
      </view>
    </label>
    <label for="js_input1" class="weui-cell weui-cell_active">
      <view class="weui-cell__hd"><text class="weui-label">手机号</text></view>
      <view class="weui-cell__bd">
        <input id="js_input1" class="weui-input" placeholder="手机号" rules="[bytelength:11]" type="number" model:value="{{phone}}" />
      </view>
    </label>
  </view>
</view>
<view class="proinfo">
  <view class="hyb">
    <image src="https://wx.pmc-wz.com/materials/logo.png" mode="widthFix" class="logo" />
    <text>慧医宝</text>
  </view>
  <view class="pro">
    <image src="https://wx.pmc-wz.com/hyb/images/{{item.picurl}}" mode="widthFix" class="proimg"></image>
    <text class="procaption">{{item.pictitle}}</text>
    <view class="spec-info" wx:if="{{item.selSpec}}">
      <text class="spec-label">已选规格：</text>
      <text class="spec-value">{{item.selSpec}}</text>
    </view>
   
  </view>
</view>
