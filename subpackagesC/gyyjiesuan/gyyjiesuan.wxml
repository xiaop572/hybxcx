<view class="wxzf">
  <view class="wxzfleft">
    <image src="https://wx.pmc-wz.com/materials/wxzfIcon.png" mode="widthFix" />
    <text>微信支付</text>
  </view>
  <radio value="" checked="true" class="wxzfright" color="#FF5C01" />
</view>
<view class="liuyanBox">
  <text>买家留言</text>
  <input type="text" placeholder="留言建议提前协商(250字以内)" model:value="{{summary}}" />
</view>
<view class="footer">
  <view class="left-content">
    <text class="money">应付：<text>¥{{finalPrice}}</text></text>
    <view class="shuliang" wx:if="{{item.depositflag!==1}}">
      <view class="numbtn" bind:tap="numjian">-</view>
      <input class="num" type="number" value="{{num}}" bindinput="onNumInput" bindblur="onNumBlur" />
      <view class="numbtn" bind:tap="numjia">+</view>
    </view>
  </view>
  <view class="buyBtn" bindtap="payment" data-item="总计:{{item}}">去支付</view>
</view>