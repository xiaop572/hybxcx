.container {
  padding: 20rpx;
  background-color: #f5f6fa;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20rpx;
}

.package-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  transform: translateY(0);
  transition: all 0.3s ease;
  width: 33%;
  box-sizing: border-box;
  margin: 0;
  display: inline-block;
  flex-direction: column;
  margin-top: 20rpx;
  text-align: center;
}

.package-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.package-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.package-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  width: 100%;
  display: inline-block;
  vertical-align: top;
  padding: 0 20rpx;
}

.package-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.package-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.package-desc {
  flex: 1;
  padding-left: 40rpx;
  border-left: 1rpx solid #eee;
  max-width: 60%;
  display: inline-block;
  vertical-align: top;
}

.desc-item {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.desc-item::before {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  background-color: #ff6b6b;
  border-radius: 50%;
  margin-right: 16rpx;
}

.form-container {
  width: 100%;
  padding: 40rpx;
  margin-top: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.form-group {
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f5f6fa;
  border-radius: 44rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4f4f 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.3s ease;
}

.submit-btn:active {
  opacity: 0.8;
}