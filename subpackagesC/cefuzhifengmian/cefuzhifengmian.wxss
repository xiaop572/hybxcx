page {
  background: linear-gradient(180deg, #52A5F9 0%, #B1D3FF 100%);
  min-height: 100%;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}
.xhfmtitle{
  width: 60%;
  display: block;
  margin: 40rpx auto 60rpx auto;
}
/* -------- 标题区 -------- */
.top-section {
  width: 100%;
  text-align: center;
  margin-bottom: 48rpx;
}
.title {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 100, 200, 0.2);
}
.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  letter-spacing: 1rpx;
}

/* -------- 图片区 -------- */
.img-section {
  position: relative;
  width: 90%;
  flex-shrink: 0;
  margin-bottom: 48rpx;
}

.img-frame {
  width: 100%;
  height: 100%;
}

.main-img {
  width: 100%;
  height: 100%;
}

/* -------- 浮动标签 -------- */
.tag {
  position: absolute;
  background: #fff;
  border-radius: 40rpx;
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  box-shadow: 0 4rpx 20rpx rgba(0, 80, 180, 0.15);
  white-space: nowrap;
}

/* 左上：检测肤质 */
.tag-left-top {
  left: -60rpx;
  top: 120rpx;
}

/* 右侧：皮肤健康评估 */
.tag-right {
  right: -80rpx;
  top: 180rpx;
}

/* 左下：测肤色 */
.tag-left-bottom {
  left: -20rpx;
  bottom: 120rpx;
}

/* -------- 底部区域 -------- */
.bottom-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  margin-top: 0rpx;
}

.hint-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius:20rpx;
  padding: 6rpx 20rpx;
}

.hint-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hint-text {
  font-size: 26rpx;
  color: #2B476B;
  letter-spacing: 0.5rpx;
}

.start-btn {
  width: 90%;
  height: 96rpx;
  background: #1076FF;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(30, 100, 200, 0.35);
  margin-top:40rpx;
}
