/* subpackagesC/dingwei/dingwei.wxss */

/* 页面容器 */
.container1 {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部蓝色背景区域 */
.header-section {
  position: relative;
  background: linear-gradient(135deg, #2196F3 0%, #42A5F5 100%);
  height: 300rpx;
  overflow: hidden;
}

/* 背景装饰圆形 */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.bg-circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.bg-circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  left: -30rpx;
  background: rgba(255, 255, 255, 0.05);
}

/* 活动信息容器 */
.activity-info {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  color: white;
}

/* 活动图标 */
.activity-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.activity-icon .icon {
  width: 50rpx;
  height: 50rpx;
}

/* 活动详情 */
.activity-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.activity-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  line-height: 1.2;
}

.activity-time {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 转发按钮 */
.share-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: white;
}

.share-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

/* 签到信息卡片 */
.checkin-card {
  background: white;
  margin: -80rpx 40rpx 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 5;
}

/* 卡片标题 */
.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 签到详情列表 */
.checkin-details {
  margin-bottom: 40rpx;
}

/* 详情项 */
.detail-item {
  display: flex;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.detail-item:last-child {
  margin-bottom: 0;
}

/* 标签样式 */
.detail-item .label {
  color: #666;
  font-size: 30rpx;
  min-width: 160rpx;
  flex-shrink: 0;
}

/* 值样式 */
.detail-item .value {
  color: #333;
  font-size: 30rpx;
  flex: 1;
}

/* 活动描述 */
.activity-description {
  text-align: center;
  padding: 30rpx 0;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 20rpx;
}

.activity-description text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 定位签到功能区域 */
.checkin-form {
  background: white;
  margin: 40rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 表单区块 */
.form-section {
  margin-bottom: 60rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.required-mark {
  color: #ff4444;
  font-size: 32rpx;
  margin-right: 8rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-right: 8rpx;
}

.section-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 姓名选择器 */
.name-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
}

/* 输入框容器 - 经典line-height方案 */
.input-container {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background: #fafafa;
  height: 88rpx;
  padding: 0 30rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  color: #999;
}

/* 输入框文字 - 行高=容器高度 */
.input-text {
  font-size: 30rpx;
  color: #999;
  line-height: 88rpx; /* 与容器同高，自然垂直居中 */
}

/* 有值时的样式 */
.input-text.has-value {
  color: #333;
}

.form-input::placeholder {
  color: #999;
}

/* 输入框聚焦状态 */
.input-container:focus-within {
  border-color: #2196F3;
  background: #fff;
}

/* 自动填写提示 */
.auto-fill-tip {
  font-size: 24rpx;
  color: #2196F3;
  margin-left: 16rpx;
}





/* 提交按钮区域 */
.submit-area {
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.submit-btn.disabled {
  background: #cccccc;
  box-shadow: none;
}

/* 姓名选择弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  transition: padding-bottom 0.3s ease;
}

.modal-container {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.name-modal {
  width: 100%;
  max-height: 70vh;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: modalShow 0.3s ease-out;
  position: relative;
}

@keyframes modalShow {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 搜索框样式 */
.search-container {
  padding: 30rpx 40rpx;
}

.search-box {
  position: relative;
  background: #f8f8f8;
  border-radius: 50rpx;
  padding: 20rpx 60rpx 20rpx 80rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  position: absolute;
  left: 30rpx;
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
}

.search-input::placeholder {
  color: #999;
}

/* 姓名列表样式 */
.name-list {
  max-height: 400rpx;
  overflow-y: auto;
  padding: 0 40rpx;
  min-height: 100rpx;
}

.name-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.name-item.selected {
  background: #e3f2fd;
  border-color: #2196F3;
}

.radio-circle {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 4rpx solid #999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.radio-circle.checked {
  border-color: #2196F3;
  background: #2196F3;
}

.radio-check {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}
.name-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

/* 按钮区域样式 */
.modal-buttons {
  display: flex;
  padding: 30rpx 40rpx 40rpx;
  gap: 20rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: #2196F3;
  color: white;
}

.cancel-btn:active {
  background: #e8e8e8;
}

.confirm-btn:active {
  background: #1976D2;
}

/* 调试信息样式 */
.debug-info {
  margin: 30rpx 0;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  border-left: 4rpx solid #2196F3;
}

.debug-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.debug-item {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

/* 右侧浮动按钮样式 */
.floating-btn {
  position: fixed;
  right: 10rpx;
  top: 300rpx;
  width: 120rpx;
  height: 120rpx;
  background: #2196F3;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 20rpx rgba(33, 150, 243, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
  transition: all 0.3s ease;
}

.floating-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.4);
}

.floating-btn-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.floating-btn-text {
  font-size: 20rpx;
  color: white;
  font-weight: 500;
}



/* 姓名选择弹窗样式 */
.name-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.name-modal-container {
  background: white;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 80vh;
  overflow: hidden;
  position: relative;
  transition: bottom 0.3s ease;
}

.name-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.name-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.name-modal-content {
  padding: 20rpx;
  max-height: 60vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.search-container {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f8f9fa;
}

.name-list {
  flex: 1;
  overflow-y: auto;
  max-height: 400rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}

.name-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.name-item:last-child {
  border-bottom: none;
}

.name-item:active {
  background: #f0f0f0;
}

.name-item.selected {
  background: #e3f2fd;
  border-color: #2196F3;
}

.name-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.check-icon {
  color: #2196F3;
  font-size: 32rpx;
  font-weight: bold;
}

.name-modal-footer {
  padding: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.confirm-btn {
  width: 100%;
  background: #2196F3;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.confirm-btn[disabled] {
  background: #ccc;
  color: #999;
}

/* 报到信息弹窗样式 */
.sign-info-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.sign-info-container {
  width: 90%;
  max-width: 600rpx;
  max-height: 80%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.sign-info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  background: #2196F3;
  color: white;
}

.sign-info-title {
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 40rpx;
  font-weight: bold;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.sign-info-content {
  max-height: 600rpx;
  overflow-y: auto;
}

.loading-container,
.empty-container {
  padding: 80rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.sign-info-list {
  padding: 20rpx 0;
}

.sign-info-item {
  margin: 20rpx 40rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border-left: 6rpx solid #2196F3;
  transition: all 0.3s ease;
}

.sign-info-item:active {
  background: #e3f2fd;
  transform: scale(0.98);
}

.sign-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.sign-info-row:last-child {
  margin-bottom: 0;
}

.sign-info-label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
  flex-shrink: 0;
}

.sign-info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.sign-info-action {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e0e0e0;
  text-align: center;
}

.view-detail-text {
  font-size: 26rpx;
  color: #2196F3;
  font-weight: 500;
}