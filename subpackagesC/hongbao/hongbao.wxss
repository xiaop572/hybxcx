.container {
  width: 100vw;
  height: 100vh;
  background: linear-gradient(180deg, #e6f3ff 0%, #b3d9ff 100%);
  position: relative;
  overflow: hidden;
}

canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100% !important;
  height: 100% !important;
  z-index: 101;
}

.popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.5s ease-out;
  background-color: rgba(0, 0, 0, 0.6);
}

.popup.show {
  opacity: 1;
  visibility: visible;
}

.card {
  background: linear-gradient(135deg, #ff4e50, #f9d423);
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
  text-align: center;
  position: relative;
  transform: scale(0.8);
  opacity: 0;
  animation: cardPop 0.5s ease-out forwards 0.3s;
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.1;
}

.card-content {
  position: relative;
  z-index: 1;
}

.title {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  animation: titleFloat 2s ease-in-out infinite;
}

.subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 40rpx;
}

.amount-wrapper {
  margin: 40rpx 0;
  animation: amountPulse 1.5s ease-in-out infinite;
}

.amount {
  font-size: 72rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.blue-button {
  background: linear-gradient(135deg, #fff, #f0f0f0);
  color: #ff4e50;
  border: none;
  padding: 24rpx 48rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 30rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: inset 0 0 20rpx rgba(255, 255, 255, 0.5), 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  animation: buttonPulse 2s ease-in-out infinite;
}

.button-hover {
  transform: scale(0.92);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  background: linear-gradient(135deg, #f0f0f0, #e6e6e6);
}

.card-decorations {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  pointer-events: none;
}

.decoration {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  animation: decorationFloat 3s ease-in-out infinite;
}

.decoration.left {
  top: 20rpx;
  left: 20rpx;
  animation-delay: 0.5s;
}

.decoration.right {
  bottom: 20rpx;
  right: 20rpx;
  animation-delay: 1s;
}

@keyframes cardPop {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes titleFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes amountPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes decorationFloat {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(10rpx, -10rpx); }
}

@keyframes buttonPulse {
  0% { transform: scale(1); box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1); }
  50% { transform: scale(1.05); box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15); }
  100% { transform: scale(1); box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1); }
}