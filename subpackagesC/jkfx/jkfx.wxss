.main {
  height: 100vh;
  background: url('https://wx.pmc-wz.com/materials/infoBg2.png') no-repeat;
  background-size: 100% auto;
  padding: 40rpx;
  box-sizing: border-box;
  text-align: center;
}

.title {
  font-size: 46rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 200rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #fff;
  margin-top: 20rpx;
}

.btn-container {
  margin-top: 40rpx;
}

.btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  margin: 30rpx auto;
  font-size: 32rpx;
}

.primary {
  background-color: #0e71ce;
  color: #fff;
}

.secondary {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}

.time-text {
  font-size: 40rpx;
  color: #0e71ce;
  margin-top:120rpx;
  opacity: 1;
  font-weight: 600;
}

.coverage-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 20rpx;
  opacity: 1;
  font-weight: 600;
}