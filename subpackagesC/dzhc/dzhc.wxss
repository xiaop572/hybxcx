page{
  padding-bottom: 0 !important;
}
/* 电子书容器 */
.ebook-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

/* 加载状态 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  text-align: center;
  color: #333;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(51, 51, 51, 0.3);
  border-top: 4rpx solid #333;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #333;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 单页电子书容器 */
.single-page-wrapper {
  width: 100vw;
  height: 100vh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1200px;
  perspective-origin: center center;
}

/* 页面容器 */
.page-container {
  width: 100vw;
  height: 100vh;
  position: relative;
  transform-style: preserve-3d;
}

/* 当前页面 */
.current-page {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  transform-style: preserve-3d;
  transform-origin: left center;
  backface-visibility: hidden;
  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

/* 下一页预览 */
.next-page {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 5;
  transform: translateZ(-1px);
  transform-style: preserve-3d;
  backface-visibility: hidden;
  will-change: transform;
}

/* 上一页预览 */
.prev-page {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  transform: rotateY(-90deg) translateZ(1px);
  transform-origin: left center;
  transform-style: preserve-3d;
  backface-visibility: visible;
  will-change: transform;
}

/* 下一页预览 - 已移除 */

/* 上一页预览 - 已移除 */

/* 页面内容 - 全屏布局 */
.page-content {
  width: 100vw;
  height: 100vh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: url("https://wx.pmc-wz.com/materials/dzhcbg.jpg") no-repeat;
  background-size: 100% 100%;
}

/* 页面图片 - widthFix模式 */
.page-image {
  width: 100%;
  display: block;
}

/* 页面编号 */
.page-number {
  position: absolute;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  z-index: 300;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

/* 移除翻页效果层 */

/* 页面背面效果 - 已移除 */

/* 触摸区域 */
.touch-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 20;
  background: transparent;
}

/* 3D翻页动画关键帧 */
@keyframes flipNext {
  0% {
    transform: rotateY(0deg);
    opacity: 1;
  }
  25% {
    transform: rotateY(-45deg);
    opacity: 1;
  }
  50% {
    transform: rotateY(-90deg);
    opacity: 1;
  }
  75% {
    transform: rotateY(-135deg);
    opacity: 1;
  }
  100% {
    transform: rotateY(-180deg);
    opacity: 1;
  }
}

@keyframes flipPrev {
  0% {
    transform: rotateY(0deg);
    opacity: 1;
  }
  100% {
    transform: rotateY(0deg);
    opacity: 1;
  }
}

@keyframes slideInNext {
  0% {
    transform: translateZ(-1px);
  }
  100% {
    transform: translateZ(0px);
  }
}

@keyframes slideInPrev {
  0% {
    transform: rotateY(-90deg) translateZ(1px);
    transform-origin: left center;
    opacity: 1;
    z-index: 10;
  }
  100% {
    transform: rotateY(0deg) translateZ(1px);
    transform-origin: left center;
    opacity: 1;
    z-index: 10;
  }
}

/* 翻页状态类 */
.flipping-next {
  animation: flipNext 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.flipping-prev {
  animation: flipPrev 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.sliding-in-next {
  animation: slideInNext 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.sliding-in-prev {
  animation: slideInPrev 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

/* 翻页效果层 */
.flip-effect {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 15;
  transform-style: preserve-3d;
}

/* 翻页阴影和高光效果已删除 */



/* 页面指示器 */
.page-indicator {
  position: absolute;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 300;
}

.indicator-content {
  background: rgba(0, 0, 0, 0.7);
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(8px);
  text-align: center;
}

.page-info {
  font-size: 26rpx;
  color: #d4af37;
  margin-bottom: 8rpx;
  display: block;
}

.progress-bar {
  width: 200rpx;
  height: 6rpx;
  background: rgba(212, 175, 55, 0.3);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(to right, #d4af37, #ffd700);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* 控制按钮 */
.control-buttons {
  position: absolute;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 40rpx;
  z-index: 300;
}

.control-btn {
  background: rgba(0, 0, 0, 0.7);
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s ease;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.control-btn:active {
  transform: scale(0.95);
  background: rgba(212, 175, 55, 0.2);
}
