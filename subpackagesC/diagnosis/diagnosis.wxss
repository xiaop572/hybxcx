/* subpageC/diagnosis/diagnosis.wxss */
page {
  background: #DBECFE;
  min-height: 100%;
}

.container1 {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 140rpx;
  box-sizing: border-box;
  background: linear-gradient(to bottom, #5AA0FF 0%, #DBECFE 50%, #DBECFE 100%);
}

/* 顶部标题 */
.header-title {
  font-size: 36rpx;
  color: #FFFFFF;
  text-align: center;
  padding:40rpx 0 0;
}

/* 主体内容区域 */
.main-content {
  position: relative;
  width: 100%;
  height: 620rpx;
  display: flex;
  justify-content: center;
}

/* 左上角装饰图片 */
.intro-img {
  position: absolute;
  top: 60rpx;
  left: 50rpx;
  width: 200rpx;
  opacity: 0.95;
}

/* 人物形象 */
.character-section {
  width: 400rpx;
  height: 600rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
}

.character-img {
  width: 70%;
  height: auto;
}

/* 提示泡泡通用样式 */
.bubble {
  position: absolute;
  background: linear-gradient(to bottom, #EAF3FE, #FEFEFE);
  border-radius: 20rpx;
  padding: 15rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  max-width: 320rpx;
}

.bubble-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 38rpx;
  white-space: pre-wrap;
  word-break: break-all;
  display: inline-block;
}

/* 泡泡1 - 右上，尾巴向下 "小慧看一眼就懂你的美" */
.bubble-1 {
  top: 140rpx;
  right: 50rpx;
}

.bubble-1::before {
  content: '';
  position: absolute;
  left: 30rpx;
  bottom: -18rpx;
  width: 0;
  height: 0;
  border-left: 15rpx solid transparent;
  border-right: 15rpx solid transparent;
  border-top: 20rpx solid #FFFFFF;
}

/* 泡泡2 - 左中下，尾巴向上 "小慧能为你量身定制变美计划" */
.bubble-2 {
  top: 300rpx;
  left: 60rpx;
}

.bubble-2::after {
  content: '';
  position: absolute;
  right: 40rpx;
  top: -18rpx;
  width: 0;
  height: 0;
  border-left: 15rpx solid transparent;
  border-right: 15rpx solid transparent;
  border-bottom: 20rpx solid #EAF3FE;
}

/* 泡泡3 - 右下，尾巴向上 "小慧能为你做一次全面的AI面诊" */
.bubble-3 {
  top: 450rpx;
  right: 30rpx;
  padding: 15rpx 16rpx;
}

.bubble-3::before {
  content: '';
  position: absolute;
  left: 60rpx;
  top: -18rpx;
  width: 0;
  height: 0;
  border-left: 15rpx solid transparent;
  border-right: 15rpx solid transparent;
  border-bottom: 20rpx solid #EAF3FE;
}

/* 变美的事找小慧卡片 */
.action-card {
  width: 670rpx;
  margin: 0 auto;
  background:url("https://wx.pmc-wz.com/materials/hmb/sckbg.png") no-repeat;
  background-size: 100% 100%;
  border-radius: 30rpx;
  padding: 20rpx 40rpx 40rpx 40rpx;
  box-sizing: border-box;
  position: relative;
}

.card-title {
  font-size: 32rpx;
  color: #FFFFFF;
  text-align: center;
  margin-bottom: 20rpx;
}

/* 上传照片区域 */
.upload-section {
  width: 100%;
}

.upload-box {
  width: 100%;
  height: 240rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.uploaded-img {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.camera-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.upload-text {
  font-size: 28rpx;
  color: #4C709E;
}

/* 底部固定区域 */
.bottom-fixed-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: transparent;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
  background: #DBECFE;
}

/* 功能按钮 */
.function-buttons {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.func-btn-wrapper {
  display: inline-flex;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.func-btn {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 50rpx;
  padding: 10rpx 15rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.func-btn:last-child {
  margin-right: 30rpx;
}

.func-icon {
  width: 40rpx;
  margin-right: 10rpx;
}

.func-text {
  font-size: 24rpx;
  color: #4C709E;
  white-space: nowrap;
}

/* 消息列表区域 */
.message-area {
  width: 100%;
  padding: 40rpx 30rpx 0;
  box-sizing: border-box;
}

.message-item {
  margin-bottom: 30rpx;
}

/* 用户消息 */
.user-message {
  display: flex;
  justify-content: flex-end;
}

.user-bubble {
  background: linear-gradient(135deg, #4A90E2 0%, #5CA3F5 100%);
  color: #FFFFFF;
  border-radius: 20rpx 20rpx 4rpx 20rpx;
  padding: 20rpx 24rpx;
  max-width: 500rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.3);
}

/* 用户图片消息气泡 */
.user-bubble-image {
  background: transparent;
  border-radius: 20rpx 20rpx 4rpx 20rpx;
  padding: 0;
  max-width: 500rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.3);
}

.message-image {
  width: 100%;
  max-width: 400rpx;
  min-width: 200rpx;
  border-radius: 20rpx 20rpx 4rpx 20rpx;
  display: block;
}

/* AI消息 */
.ai-message {
  display: flex;
  justify-content: flex-start;
}

.ai-bubble {
  background: #FFFFFF;
  color: #333333;
  border-radius: 20rpx 20rpx 20rpx 4rpx;
  padding: 20rpx 24rpx;
  max-width: 500rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.ai-text {
  display: block;
  margin-bottom: 10rpx;
}

.ai-hashtag {
  display: block;
  color: #4A90E2;
  font-weight: 500;
}

/* AI加载卡片 */
.loading-card {
  background: linear-gradient(135deg, rgba(234, 243, 254, 0.95) 0%, rgba(255, 255, 255, 0.95) 100%);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  max-width: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E0E0E0;
  border-top-color: #4A90E2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
}

.loading-subtext {
  font-size: 24rpx;
  color: #999999;
}

/* 输入框区域 */
.input-section {
  background: transparent;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}

.camera-btn {
  width: 88rpx;
  height: 88rpx;
  margin-right: 15rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.camera-icon-btn {
  width: 48rpx;
  height: 48rpx;
}

.message-input {
  flex: 1;
  height: 88rpx;
  background: #FFFFFF;
  border-radius: 44rpx;
  padding: 0 110rpx 0 30rpx;
  font-size: 28rpx;
  color: #333333;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

/* 欢迎页输入框（没有相机按钮时） */
.input-full {
  margin-left: 0;
}

.send-btn {
  position: absolute;
  right: 32rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.send-icon {
  width: 76rpx;
}

/* 见面礼弹窗 */
.gift-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.gift-modal-content {
  position: relative;
  width: 600rpx;
  background: transparent;
  display: flex;
  justify-content: center;
  align-items: center;
}

.gift-modal-button {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  width: 100% !important;
  display: flex;
  justify-content: center;
  align-items: center;
}

.gift-modal-button::after {
  border: none;
}

.gift-modal-image {
  width: 80%;
  border-radius: 16rpx;
}

.gift-modal-close {
  position: absolute;
  top: -60rpx;
  right: 0;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  color: #333;
  font-weight: bold;
}

/* AI消息中的见面礼链接样式 */
.gift-link-text {
  color: #4A90E2;
  font-weight: 500;
  text-decoration: underline;
}

/* 实名验证弹窗 */
.real-name-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 10000;
  display: flex;
  justify-content: center;
  align-items: center;
}

.real-name-modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
}

.real-name-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 16rpx;
}

.real-name-subtitle {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 50rpx;
}

.real-name-input-group {
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.real-name-input {
  width: 100%;
  height: 88rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.phone-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.phone-input {
  flex: 1;
}

.get-phone-btn {
  width: 160rpx !important;
  height: 58rpx;
  background: linear-gradient(135deg, #5AA0FF 0%, #4A8FEE 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 88rpx;
}

.get-phone-btn::after {
  border: none;
}

.privacy-agreement {
  margin-top: 30rpx;
  margin-bottom: 20rpx;
}

.privacy-checkbox {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666666;
}

.privacy-text {
  margin-left: 12rpx;
  color: #666666;
}

.real-name-submit-btn {
  width: 80%;
  height: 72rpx;
  background: linear-gradient(135deg, #5AA0FF 0%, #4A8FEE 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FFFFFF;
  margin: 40rpx auto 0;
  box-shadow: 0 8rpx 16rpx rgba(90, 160, 255, 0.3);
}