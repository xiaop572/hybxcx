/* subpackagesC/mianzhenjieguo/mianzhenjieguo.wxss */
page {
  background: linear-gradient(160deg, #efe8fb 0%, #dbe8f8 100%);
  min-height: 100%;
  height: 100%;
}

.chat-page {
  position: relative;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  height: 100vh;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 32rpx rgba(124, 92, 246, 0.08);
}

.header-card {
  padding: 40rpx 36rpx 36rpx;
  margin-bottom: 24rpx;
}

.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.header-left {
  flex: 1;
  padding-right: 24rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #222222;
  line-height: 1.3;
}

.sub-title {
  margin-top: 16rpx;
  font-size: 25rpx;
  color: #7a7f8f;
  line-height: 1.8;
}

.header-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a78bfa 0%, #38bdf8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.summary-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 156rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 26rpx;
  background: linear-gradient(90deg, rgba(124, 92, 246, 0.12), rgba(56, 189, 248, 0.12));
  color: #6a53dd;
  font-size: 24rpx;
  font-weight: 600;
}

.summary-text {
  margin-top: 20rpx;
  font-size: 27rpx;
  color: #545b66;
  line-height: 1.9;
  white-space: pre-wrap;
}

.overview-row {
  display: flex;
  margin-top: 28rpx;
  gap: 20rpx;
}

.overview-pill {
  flex: 1;
  min-width: 0;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #faf8ff 0%, #f2f8ff 100%);
}

.overview-pill-label {
  display: block;
  font-size: 22rpx;
  color: #96a0af;
  margin-bottom: 10rpx;
}

.overview-pill-value {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #5a44d6;
  line-height: 1.4;
  word-break: break-all;
}

.section-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2b2b2b;
  line-height: 1.4;
}

.section-tip {
  font-size: 22rpx;
  color: #9aa0ab;
  flex-shrink: 0;
}

.photo-wrap {
  width: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #f7f8ff 0%, #eef4ff 100%);
  border: 2rpx solid rgba(124, 92, 246, 0.08);
}

.face-image {
  width: 100%;
  display: block;
}

.photo-wrap-empty {
  min-height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-empty,
.empty-text {
  font-size: 26rpx;
  color: #9aa0ab;
  line-height: 1.8;
}

.photo-caption {
  margin-top: 18rpx;
  font-size: 23rpx;
  color: #98a0ad;
  line-height: 1.8;
}

.feature-list {
  display: flex;
  flex-direction: column;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #faf8ff 0%, #f5f9ff 100%);
  margin-bottom: 20rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  background: linear-gradient(135deg, #7c5cf6 0%, #38bdf8 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feature-main {
  flex: 1;
  min-width: 0;
}

.feature-text {
  flex: 1;
  font-size: 27rpx;
  color: #4d5561;
  line-height: 1.85;
  word-break: break-all;
}

.content-panel {
  border-radius: 28rpx;
  padding: 28rpx 26rpx;
}

.content-panel-purple {
  background: linear-gradient(180deg, rgba(124, 92, 246, 0.09) 0%, rgba(124, 92, 246, 0.03) 100%);
}

.content-panel-blue {
  background: linear-gradient(180deg, rgba(56, 189, 248, 0.12) 0%, rgba(56, 189, 248, 0.04) 100%);
}

.content-line {
  font-size: 27rpx;
  color: #4d5561;
  line-height: 1.9;
  white-space: pre-wrap;
  margin-bottom: 18rpx;
}

.content-line:last-child {
  margin-bottom: 0;
}

.fun-list {
  display: flex;
  flex-direction: column;
}

.fun-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.fun-item:last-child {
  margin-bottom: 0;
}

.fun-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  margin-right: 16rpx;
  background: linear-gradient(135deg, #7c5cf6 0%, #a76dff 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.fun-text {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  color: #4d5561;
  line-height: 1.9;
  word-break: break-all;
  white-space: pre-wrap;
}

.emotion-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.emotion-item {
  min-width: 160rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #eff5ff 0%, #f7f2ff 100%);
  border: 1rpx solid rgba(124, 92, 246, 0.12);
}

.emotion-name {
  font-size: 22rpx;
  color: #7f8ba0;
  line-height: 1.3;
}

.emotion-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #4f39cf;
  font-weight: 700;
  line-height: 1.2;
}

.ent-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ent-card {
  width: calc((100% - 16rpx) / 2);
  box-sizing: border-box;
  border-radius: 22rpx;
  padding: 22rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(124, 92, 246, 0.18);
}

.ent-card-wide {
  width: 100%;
  background: linear-gradient(180deg, rgba(124, 92, 246, 0.08) 0%, rgba(124, 92, 246, 0.02) 100%);
}

.ent-card-title {
  font-size: 27rpx;
  color: #3f2aae;
  font-weight: 700;
  line-height: 1.4;
}

.ent-card-content {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: #4d5561;
  line-height: 1.75;
  white-space: pre-wrap;
}

.ent-note {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #9aa0ab;
  line-height: 1.6;
}

.chat-section {
  margin-bottom: 0;
}

.chat-tips {
  font-size: 24rpx;
  color: #8e96a6;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.chat-list {
  display: flex;
  flex-direction: column;
}

.chat-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.chat-item:last-child {
  margin-bottom: 0;
}

.chat-item-user {
  flex-direction: row-reverse;
}

.chat-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #7c5cf6 0%, #38bdf8 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat-item-user .chat-avatar {
  background: linear-gradient(135deg, #ff8a65 0%, #ffb74d 100%);
}

.chat-main {
  max-width: calc(100% - 90rpx);
  display: flex;
  flex-direction: column;
  margin-left: 16rpx;
}

.chat-item-user .chat-main {
  margin-left: 0;
  margin-right: 16rpx;
  align-items: flex-end;
}

.chat-image {
  width: 280rpx;
  height: 280rpx;
  border-radius: 24rpx;
  margin-bottom: 12rpx;
  background: #f3f5fa;
}

.chat-bubble {
  max-width: 100%;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  font-size: 27rpx;
  line-height: 1.8;
  word-break: break-word;
  white-space: pre-wrap;
  box-sizing: border-box;
}

.chat-bubble-assistant {
  background: #f5f7ff;
  color: #445064;
  border-top-left-radius: 10rpx;
}

.chat-bubble-user {
  background: linear-gradient(135deg, #7c5cf6 0%, #5baef5 100%);
  color: #ffffff;
  border-top-right-radius: 10rpx;
}

.page-bottom-space {
  height: 280rpx;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 28rpx rgba(77, 85, 97, 0.08);
  backdrop-filter: blur(16rpx);
  box-sizing: border-box;
}

.composer-preview {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 14rpx 10rpx 10rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #f6f7fb;
}

.composer-preview-image {
  width: 84rpx;
  height: 84rpx;
  border-radius: 16rpx;
  margin-right: 14rpx;
  background: #e9edf3;
}

.composer-preview-remove {
  font-size: 24rpx;
  color: #f26d6d;
  line-height: 1.4;
}

.composer-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.composer-upload {
  flex-shrink: 0;
  min-width: 98rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 38rpx;
  background: #f3f5fb;
  color: #5f6a7a;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.composer-upload-icon {
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
  display: block;
}

.composer-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 26rpx;
  border-radius: 38rpx;
  background: #f5f7fb;
  font-size: 26rpx;
  color: #2b2b2b;
  box-sizing: border-box;
}

.composer-send {
  flex-shrink: 0;
  min-width: 104rpx;
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 38rpx;
  background: #d6d9e2;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.composer-send-active {
  background: linear-gradient(135deg, #7c5cf6 0%, #38bdf8 100%);
}
