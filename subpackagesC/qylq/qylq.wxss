page{
  padding-bottom: 0 !important;
}
.container1 {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.banner {
  width: 100%;
  height: auto;
}

.content-box {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -60rpx;
  position: relative;
  z-index: 10;
}

.product-image {
  width: 100%;
  height: auto;
  margin-bottom: 30rpx;
}

.form-container {
  width: 100%;
  background-color: #fff;
  border-radius: 60rpx;
  padding: 60rpx;
  box-sizing: border-box;
}

.form-title {
  font-size: 32rpx;
  color: #000;
  margin-bottom: 20rpx;
}

.form-card {
  border-radius: 12rpx;
  color: #333;
  display: flex;
  align-items: flex-start;
  border-bottom: 1px solid #ddd;
  padding-bottom: 60rpx;
}

.product-image {
  width:50%;
  height: auto;
  margin-right: 30rpx;
  margin-bottom: 0;
}

.card-info {
  flex: 1;
  text-align: left;
  padding-top: 10rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
}

.card-price {
  font-size: 28rpx;
  opacity: 0.8;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-group {
  width: 100%;
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  background-color: rgb(233, 243, 255);
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  margin-top: 20rpx;
}

.input:focus {
  border-color: #0172f2;
  box-shadow: 0 4rpx 16rpx rgba(1, 114, 242, 0.1);
}

.submit-btn {
  display: block;
  width: 60%;
  height: 70rpx;
  align-items: center;
  justify-content: center;
  background: #0172f2;
  color: #FFFFFF;
  border-radius: 10rpx;
  margin: auto;
  margin-top: 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  line-height: 70rpx;
  letter-spacing: 6rpx;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.float-button {
  position: fixed;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  z-index: 999;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.float-button image {
  width: 100%;
  height: auto;
}

