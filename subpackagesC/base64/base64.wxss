.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f8f8f8;
}

.input-area {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  width: 100%;
}

.base64-input {
  width: 100%;
  height: 400rpx;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 20rpx;
  box-sizing: border-box;
  border: 1px solid #e0e0e0;
  border-radius: 8rpx;
}

.preview-area {
  width: 100%;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.preview-image {
  width: 100%;
  max-height: 600rpx;
  border-radius: 8rpx;
}

.button-group {
  text-align: center;
  margin-top: 30rpx;
}

.convert-btn, .save-btn {
  display: inline-block;
  width: 45%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 40rpx;
  background: #0172f2;
  color: #fff;
  letter-spacing: 4rpx;
  margin: 0 10rpx;
  text-align: center;
}

.convert-btn:active, .save-btn:active {
  opacity: 0.8;
}

.loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  text-align: center;
}

.loading-text {
  color: #fff;
  font-size: 32rpx;
  background: rgba(0, 0, 0, 0.7);
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-top: 50%;
}