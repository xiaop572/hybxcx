<svg width="200" height="280" viewBox="0 0 200 280" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="hyGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff9a9e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#fecfef;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="2" dy="4" stdDeviation="3" flood-color="rgba(0,0,0,0.3)"/>
    </filter>
  </defs>
  
  <!-- 卡片背景 -->
  <rect x="10" y="10" width="180" height="260" rx="15" ry="15" fill="url(#hyGradient)" filter="url(#shadow)"/>
  
  <!-- 装饰边框 -->
  <rect x="15" y="15" width="170" height="250" rx="12" ry="12" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2"/>
  
  <!-- 标题区域 -->
  <rect x="25" y="25" width="150" height="50" rx="8" ry="8" fill="rgba(255,255,255,0.2)"/>
  <text x="100" y="45" text-anchor="middle" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white">焕颜卡</text>
  <text x="100" y="62" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="rgba(255,255,255,0.9)">BEAUTY CARD</text>
  
  <!-- 主图标 -->
  <circle cx="100" cy="140" r="35" fill="rgba(255,255,255,0.3)"/>
  <path d="M85 130 Q100 115 115 130 Q100 145 85 130" fill="white"/>
  <circle cx="92" cy="135" r="3" fill="#ff6b9d"/>
  <circle cx="108" cy="135" r="3" fill="#ff6b9d"/>
  <path d="M95 145 Q100 150 105 145" stroke="#ff6b9d" stroke-width="2" fill="none"/>
  
  <!-- 装饰元素 -->
  <circle cx="60" cy="100" r="4" fill="rgba(255,255,255,0.6)"/>
  <circle cx="140" cy="110" r="3" fill="rgba(255,255,255,0.4)"/>
  <circle cx="70" cy="180" r="5" fill="rgba(255,255,255,0.5)"/>
  <circle cx="130" cy="190" r="4" fill="rgba(255,255,255,0.3)"/>
  
  <!-- 底部文字 -->
  <text x="100" y="210" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white">让您焕发青春光彩</text>
  <text x="100" y="230" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="rgba(255,255,255,0.8)">Beauty & Youth</text>
  
  <!-- 序列号 -->
  <text x="100" y="250" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="rgba(255,255,255,0.6)">No. HY-2024</text>
</svg>