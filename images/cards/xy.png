<svg width="200" height="280" viewBox="0 0 200 280" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="xyGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffecd2;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#fcb69f;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="2" dy="4" stdDeviation="3" flood-color="rgba(0,0,0,0.3)"/>
    </filter>
  </defs>
  
  <!-- 卡片背景 -->
  <rect x="10" y="10" width="180" height="260" rx="15" ry="15" fill="url(#xyGradient)" filter="url(#shadow)"/>
  
  <!-- 装饰边框 -->
  <rect x="15" y="15" width="170" height="250" rx="12" ry="12" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2"/>
  
  <!-- 标题区域 -->
  <rect x="25" y="25" width="150" height="50" rx="8" ry="8" fill="rgba(255,255,255,0.2)"/>
  <text x="100" y="45" text-anchor="middle" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white">馨悦卡</text>
  <text x="100" y="62" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="rgba(255,255,255,0.9)">JOY CARD</text>
  
  <!-- 主图标 - 笑脸+花朵 -->
  <circle cx="100" cy="140" r="35" fill="rgba(255,255,255,0.3)"/>
  <!-- 笑脸 -->
  <circle cx="100" cy="140" r="25" fill="white" stroke="#ff9068" stroke-width="2"/>
  <circle cx="92" cy="133" r="3" fill="#ff9068"/>
  <circle cx="108" cy="133" r="3" fill="#ff9068"/>
  <path d="M88 145 Q100 155 112 145" stroke="#ff9068" stroke-width="3" fill="none"/>
  
  <!-- 花朵装饰 -->
  <g transform="translate(75,115)">
    <circle cx="0" cy="0" r="4" fill="#ffb347"/>
    <circle cx="-6" cy="-3" r="3" fill="#ff9068"/>
    <circle cx="6" cy="-3" r="3" fill="#ff9068"/>
    <circle cx="-4" cy="6" r="3" fill="#ff9068"/>
    <circle cx="4" cy="6" r="3" fill="#ff9068"/>
  </g>
  
  <g transform="translate(125,165)">
    <circle cx="0" cy="0" r="3" fill="#ffb347"/>
    <circle cx="-4" cy="-2" r="2" fill="#ff9068"/>
    <circle cx="4" cy="-2" r="2" fill="#ff9068"/>
    <circle cx="-3" cy="4" r="2" fill="#ff9068"/>
    <circle cx="3" cy="4" r="2" fill="#ff9068"/>
  </g>
  
  <!-- 装饰元素 -->
  <circle cx="65" cy="105" r="4" fill="rgba(255,255,255,0.6)"/>
  <circle cx="135" cy="115" r="3" fill="rgba(255,255,255,0.4)"/>
  <circle cx="70" cy="175" r="5" fill="rgba(255,255,255,0.5)"/>
  <circle cx="130" cy="185" r="4" fill="rgba(255,255,255,0.3)"/>
  
  <!-- 心形装饰 -->
  <path d="M60 160 C58 155, 52 155, 52 150 C52 147, 55 145, 60 150 C65 145, 68 147, 68 150 C68 155, 62 155, 60 160 Z" fill="rgba(255,255,255,0.7)"/>
  <path d="M140 125 C138 122, 134 122, 134 119 C134 117, 136 116, 140 119 C144 116, 146 117, 146 119 C146 122, 142 122, 140 125 Z" fill="rgba(255,255,255,0.7)"/>
  
  <!-- 底部文字 -->
  <text x="100" y="210" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white">愿您心情愉悦舒畅</text>
  <text x="100" y="230" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="rgba(255,255,255,0.8)">Joy & Happiness</text>
  
  <!-- 序列号 -->
  <text x="100" y="250" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="rgba(255,255,255,0.6)">No. XY-2024</text>
</svg>