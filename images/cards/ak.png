<svg width="200" height="280" viewBox="0 0 200 280" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="akGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#a8e6cf;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#dcedc1;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="2" dy="4" stdDeviation="3" flood-color="rgba(0,0,0,0.3)"/>
    </filter>
  </defs>
  
  <!-- 卡片背景 -->
  <rect x="10" y="10" width="180" height="260" rx="15" ry="15" fill="url(#akGradient)" filter="url(#shadow)"/>
  
  <!-- 装饰边框 -->
  <rect x="15" y="15" width="170" height="250" rx="12" ry="12" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2"/>
  
  <!-- 标题区域 -->
  <rect x="25" y="25" width="150" height="50" rx="8" ry="8" fill="rgba(255,255,255,0.2)"/>
  <text x="100" y="45" text-anchor="middle" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white">安康卡</text>
  <text x="100" y="62" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="rgba(255,255,255,0.9)">HEALTH CARD</text>
  
  <!-- 主图标 - 心形+十字 -->
  <circle cx="100" cy="140" r="35" fill="rgba(255,255,255,0.3)"/>
  <!-- 心形 -->
  <path d="M100 155 C95 145, 80 145, 80 130 C80 120, 90 115, 100 125 C110 115, 120 120, 120 130 C120 145, 105 145, 100 155 Z" fill="white"/>
  <!-- 十字标志 -->
  <rect x="97" y="130" width="6" height="20" fill="#4caf50"/>
  <rect x="90" y="137" width="20" height="6" fill="#4caf50"/>
  
  <!-- 保护盾牌轮廓 -->
  <path d="M85 120 Q100 110 115 120 L115 150 Q100 165 85 150 Z" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2"/>
  
  <!-- 装饰元素 -->
  <circle cx="70" cy="100" r="4" fill="rgba(255,255,255,0.6)"/>
  <circle cx="130" cy="110" r="3" fill="rgba(255,255,255,0.4)"/>
  <circle cx="75" cy="180" r="5" fill="rgba(255,255,255,0.5)"/>
  <circle cx="125" cy="190" r="4" fill="rgba(255,255,255,0.3)"/>
  
  <!-- 健康符号 -->
  <path d="M60 120 L65 125 L75 115" stroke="rgba(255,255,255,0.7)" stroke-width="2" fill="none"/>
  <path d="M125 115 L130 120 L140 110" stroke="rgba(255,255,255,0.7)" stroke-width="2" fill="none"/>
  
  <!-- 底部文字 -->
  <text x="100" y="210" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white">祝您身体健康平安</text>
  <text x="100" y="230" text-anchor="middle" font-family="Arial, sans-serif" font-size="10" fill="rgba(255,255,255,0.8)">Health & Safety</text>
  
  <!-- 序列号 -->
  <text x="100" y="250" text-anchor="middle" font-family="Arial, sans-serif" font-size="8" fill="rgba(255,255,255,0.6)">No. AK-2024</text>
</svg>