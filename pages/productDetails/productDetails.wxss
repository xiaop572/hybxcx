}
.price{
  margin: 20rpx;
  font-size: 32rpx;
  color: red;
  font-weight: bold;
  display: block;
}
.proHeader{
  padding-bottom: 30rpx;
  border-bottom: 1px solid #eee;
  background-color: #fff;
}