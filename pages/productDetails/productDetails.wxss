/* pages/productDetails/productDetails.wxss */
page{
  background-color: #f2f2f2;
}
.proPicture{
  width: 100%;
  display: block;
}
.proTitle{
  display: block;
  font-weight: bold;
  margin: 20rpx 0 0 20rpx;
