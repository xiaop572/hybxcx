<wxs module="m1">
  var rq = function (r) {
    var da = getDate(r)
    var dataStr = da.getFullYear() + "-" + (da.getMonth() + 1) + "-" + da.getDate();
    return dataStr;
  }
  module.exports.rq = rq;
  var time = function (r) {
    var da = getDate(r)

    var dataStr = da.getHours() + ":" + (da.getMinutes() < 10 ? '0' + da.getMinutes() : da.getMinutes());
    return dataStr;
  }
  module.exports.time = time;
  var floor = function (r) {
    return Math.floor(r)
  }
  module.exports.floor = floor;
  var getDiscountPrice = function (pointsDeduction, price) {
    var discount = parseFloat(pointsDeduction) - parseFloat(price);
    return discount.toFixed(2);
  }
  module.exports.getDiscountPrice = getDiscountPrice;
  var formatDate = function (dateString) {
    if (!dateString) {
      return '';
    }
    var datePart = dateString.split('T')[0];
    var date = getDate(datePart.split('-').join('/'));
    var month = date.getMonth() + 1;
    var day = date.getDate();
    return (month < 10 ? '0' + month : month) + '.' + (day < 10 ? '0' + day : day);
  }
  module.exports.formatDate = formatDate;
  var getPercent = function (sanum, kc) {
    if (!kc || kc == 0) {
      return 0;
    }
    var percent = (sanum / kc) * 100;
    if (percent > 100) {
      return 100;
    }
    return Math.floor(percent);
  }
  module.exports.getPercent = getPercent;
</wxs>
