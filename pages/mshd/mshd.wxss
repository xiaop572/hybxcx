.progress-track {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  left: 0;
  right: 0;
  height: 30rpx;
  background: url("https://wx.pmc-wz.com/materials/jdtBg.png") no-repeat;
  background-size: 100% 100%;
  border-radius: 20rpx;
  overflow: visible;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
}
.progress-fill {
  position: relative;
  height: 20rpx;
  background: url("https://wx.pmc-wz.com/materials/jdtjd.png") repeat-x;
  background-size: auto 100%;
  border-radius: 20rpx;
  transition: width 0.5s ease;
  overflow: visible;
  min-width: 5%;
  z-index: 1;
}
.current-bubble-wrapper {
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  z-index: 100;
  pointer-events: none;
}
.progress-dot {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translate(50%, -50%);
  width: 50rpx;
  z-index: 10;
}
.current-bubble {
  position: absolute;
  right: 0;
  top: -90rpx;
  background: url("https://wx.pmc-wz.com/materials/qipaobg.png") no-repeat;
  background-size: 100% 100%;
  color: #fff;
  padding: 15rpx 30rpx;
  font-size: 24rpx;
  white-space: nowrap;
  min-width: 100rpx;
  height: 60rpx;
  text-align: center;
  transform: translateX(50%);
}
.gift-icon {
  position: absolute;
  right: 0;
  top: -15rpx;
  width: 50rpx;
  animation: bounce 1s infinite;
  transform: translateX(50%);
  z-index: 100;
}
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
.milestones {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 35rpx;
  z-index: 10;
}
.milestone {
  position: absolute;
  transform: translateX(-50%);
}
.milestone-icon {
  position: absolute;
  width: 120rpx;
  top: -70rpx;
  left: 50%;
  transform: translateX(-50%);
  transition: all 0.3s ease;
  z-index: 10;
}
.milestone.reached .milestone-icon {
  animation: pulse 0.5s ease;
}
@keyframes pulse {
  0% { transform: translateX(-50%) scale(1); }
  50% { transform: translateX(-50%) scale(1.2); }
  100% { transform: translateX(-50%) scale(1); }
}
.milestone-label {
  position: absolute;
  top: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: #fff;
  white-space: nowrap;
}
