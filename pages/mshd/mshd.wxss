/* 礼盒弹框样式 */
.gift-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.gift-modal-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.gift-animation-bg {
  width: 530rpx;
  display: block;
  margin-bottom: -80rpx;
  z-index: 1;
  margin-left: 50rpx;
}

.gift-dialog {
  width: 550rpx;
  background: linear-gradient(to bottom, #A3CCFD, #ffD9CE);
  border-radius: 30rpx;
  padding: 60rpx 40rpx 50rpx;
  box-sizing: border-box;
  text-align: center;
  position: relative;
  z-index: 2;
  box-shadow: 
    0 0 30rpx 10rpx rgba(255, 255, 255, 0.6),
    0 0 50rpx 15rpx rgba(255, 255, 255, 0.3),
    0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  overflow: visible;
  animation: giftGlow 2s ease-in-out infinite alternate;
}

@keyframes giftGlow {
  0% {
    box-shadow: 
      0 0 30rpx 10rpx rgba(255, 255, 255, 0.6),
      0 0 50rpx 15rpx rgba(255, 255, 255, 0.3),
      0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  }
  100% {
    box-shadow: 
      0 0 40rpx 12rpx rgba(255, 255, 255, 0.7),
      0 0 60rpx 18rpx rgba(255, 255, 255, 0.4),
      0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  }
}

