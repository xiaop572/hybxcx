<!--huodongpage/jifu/jifu.wxml-->
<view class="container1">
  <image src="https://wx.pmc-wz.com/materials/jifubanner.png" mode="widthFix" class="banner" />
  <!-- 活动规则按钮 -->
  <image src="https://wx.pmc-wz.com/materials/msjifu.png" mode="widthFix" class="jifucap" />
  <view class="rules-btn" bindtap="showRules">活动规则</view>
  <!-- 主内容区域 -->
  <!-- 卡片展示区域 -->
      <!-- 卡片网格 -->
      <view class="card-grid">
        <view class="collected-count">{{collectedCount}}人已集齐卡片</view>
        <!-- 第一行：前3张卡片 -->
        <view class="card-row">
          <view wx:for="{{cardConfigs}}" wx:for-index="index" wx:key="id" wx:if="{{index < 3}}" class="card {{userCards[item.key] ? 'active' : ''}}" data-card="{{item.key}}" data-cardid="{{item.id}}" data-cardname="{{item.name}}" data-hascard="{{userCards[item.key]}}" bindtap="exchangeSingleCard">
              <image class="card-bg" src="{{baseImageUrl + (userCards[item.key] ? item.ownedImage : item.unownedImage)}}" mode="widthFix"></image>
          </view>
        </view>
        <!-- 第二行：剩余卡片 -->
        <view class="card-row">
          <view wx:for="{{cardConfigs}}" wx:for-index="index" wx:key="id" wx:if="{{index >= 3}}" class="card {{userCards[item.key] ? 'active' : ''}}" data-card="{{item.key}}" data-cardid="{{item.id}}" data-cardname="{{item.name}}" data-hascard="{{userCards[item.key]}}" bindtap="exchangeSingleCard">
            <view class="card-wrapper">
              <image class="card-bg" src="{{baseImageUrl + (userCards[item.key] ? item.ownedImage : item.unownedImage)}}" mode="widthFix"></image>
            </view>
          </view>
        </view>
        <image src="{{baseImageUrl}}{{isComplete ? 'hcfk.png' : 'whcfk.png'}}" mode="widthFix" class="hcfk" bindtap="showCompose" />
      </view>
      <image src="https://wx.pmc-wz.com/materials/msnafu.png" mode="widthFix" class="jifucap" style="margin-top: 60rpx;"/>
      <image src="https://wx.pmc-wz.com/materials/pldfq.png" mode="widthFix" class="dfq" bind:tap="rtcxq" data-tcid="2892"/>
      <image src="https://wx.pmc-wz.com/materials/axdfq.png" mode="widthFix" class="dfq" bind:tap="rtcxq" data-tcid="2888"/>
      <image src="https://wx.pmc-wz.com/materials/jkdfq.png" mode="widthFix" class="dfq" bind:tap="rtcxq" data-tcid="2889"/>
      <image src="https://wx.pmc-wz.com/materials/yqdfq.png" mode="widthFix" class="dfq" bind:tap="rtcxq" data-tcid="2890"/>
  <!-- 活动规则弹窗 -->
  <view class="rules-popup" wx:if="{{showRulesPopup}}">
    <view class="rules-content-wrap">
      <view class="rules-close" bindtap="closeRules">×</view>
      <image class="rules-img" src="{{baseImageUrl}}hdgz.png" mode="widthFix" bindtap="noop" />
    </view>
    <view class="rules-mask" bindtap="closeRules"></view>
  </view>

  <!-- 首次进入欢迎弹窗 -->
  <view class="welcome-overlay" wx:if="{{showWelcomePopup}}">
    <view class="welcome-popup">
      <view class="welcome-title">恭喜获得</view>
      <image src="https://wx.pmc-wz.com/materials/ymfg.png" mode="widthFix" class="getcard" />
      <view class="welcome-button" bindtap="claimCard">开心收下</view>
    </view>
  </view>

  <!-- 兑换确认弹窗 -->
  <view class="exchange-overlay" wx:if="{{showExchangePopup}}">
    <view class="exchange-popup">
      <view class="exchange-title">
        <text>确认用</text>
        <text class="card-name-highlight">【{{exchangeCardInfo.name}}】</text>
        <text>兑换吗？</text>
      </view>
      <view class="exchange-image-wrapper">
        <image src="{{baseImageUrl}}{{exchangeImages[exchangeCardInfo.name]}}" mode="widthFix" class="exchange-image"/>
      </view>
      <view class="exchange-buttons">
        <view class="exchange-confirm-btn" bindtap="confirmExchange">确认兑换</view>
        <view class="exchange-cancel-btn" bindtap="cancelExchange">取消去集福</view>
      </view>
      <view class="exchange-tip">*兑换后将不可兑换其他福卡礼及合成福卡</view>
    </view>
    <view class="exchange-close" bindtap="cancelExchange">×</view>
  </view>

  <!-- 小福袋合成确认弹窗 -->
  <view class="compose-overlay" wx:if="{{showComposePopup}}">
    <view class="compose-popup">
      <view class="compose-title">
        <text>您确定要合成兑换</text>
        <text class="compose-title-highlight">【健康美小福袋】</text>
        <text>吗？</text>
      </view>
      <view class="compose-image-wrapper">
        <image src="{{baseImageUrl}}wfhfd.png" mode="widthFix" class="compose-image"/>
      </view>
      <view class="compose-buttons">
        <view class="compose-confirm-btn" bindtap="confirmCompose">确认合成</view>
        <view class="compose-cancel-btn" bindtap="cancelCompose">取消去集福</view>
      </view>
      <view class="compose-tip">您还差一张<text class="ys">万能福"</text>即可兑换健康美大福袋</view>
      <view class="compose-tip2">*合成后将不可兑换其他福卡礼及合成大福袋</view>
    </view>
    <view class="compose-close" bindtap="cancelCompose">×</view>
  </view>

  <!-- 大福袋合成确认弹窗 -->
  <view class="big-compose-overlay" wx:if="{{showBigComposePopup}}">
    <view class="big-compose-popup">
      <view class="big-compose-title">
        <text>您确定要合成兑换</text>
        <text class="big-compose-title-highlight">【健康美大福袋】</text>
        <text>吗？</text>
      </view>
      <view class="big-compose-image-wrapper">
        <image src="{{baseImageUrl}}wfhfdb.png" mode="widthFix" class="big-compose-image"/>
      </view>
      <view class="big-compose-desc">
        <text>2026速美V脸尊享卡、2026家庭口腔健康年卡、</text>
        <text>优享健体检套餐、2026产后康复金卡</text>
        <text>（4选1）</text>
      </view>
      <view class="big-compose-buttons">
        <view class="big-compose-confirm-btn" bindtap="confirmBigCompose">确认合成</view>
        <view class="big-compose-cancel-btn" bindtap="cancelBigCompose">取消去集福</view>
      </view>
      <view class="big-compose-tip">*合成后将不可兑换其他福卡礼</view>
    </view>
    <view class="big-compose-close" bindtap="cancelBigCompose">×</view>
  </view>

  <!-- 兑换成功弹窗 -->
  <view class="success-overlay" wx:if="{{showSuccessPopup}}">
    <view class="success-popup">
      <image src="{{baseImageUrl}}{{successPopupBg}}" mode="widthFix" class="success-bg"/>
      <view class="success-content">
        <view class="success-gift-name">【{{successGiftInfo.name}}】</view>
        <view class="success-gift-wrapper">
          <image src="{{baseImageUrl}}{{successGiftInfo.image}}" mode="widthFix" class="success-gift-image"/>
        </view>
        <view class="success-desc" wx:if="{{successGiftInfo.desc}}">{{successGiftInfo.desc}}</view>
        <view class="success-button" bindtap="closeSuccessPopup">开心收下</view>
      </view>
    </view>
    <view class="success-close" bindtap="closeSuccessPopup">×</view>
  </view>
</view>