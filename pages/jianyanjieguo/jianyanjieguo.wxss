/* subpackages/jianyanjieguo/jianyanjieguo.wxss */
@import "../../wxParse/wxParse/wxParse.wxss";
.danxiangItem {
    margin: 20rpx auto 0 auto;
    background: #fff;
    width: 92%;
    box-sizing: border-box;
    padding: 40rpx 30rpx;
    border-radius: 20rpx;
    font-size: #000;
    border: 1px solid #d5e0fa;
}

.danxiangItem .one {
    font-weight: bold;
    color: #333;
}

.danxiangItem .two {
    display: block;
    margin: 20rpx 0;
    font-size: 14px;
    color: #999;
}

.danxiangItem .tree {
    font-size: 14px;
    color: #333;
}

.danxiangItem .four {
    font-size: 14px;
    color: #666;
    margin-left: 5rpx;
}

.danxiangContent {
    padding-bottom: 20rpx;
}

.danxiangItem .five {
    font-size: 16px;
    color: #333;
}

.danxiangItem .blue {
    color: blue;
}

.danxiangItem .red {
    color: red;
}

.aifxbtn {
    background-color: #22a3f4;
    color: #fff;
}

.aibox {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: white;
    border: 1px solid #ccc;
    border-radius: 5px;
    padding: 10rpx 50rpx 50rpx 50rpx;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    width: 80%;
    max-width: 600rpx;
    max-height: 900rpx;

}

.aifxhead {
    display: flex;
    justify-content: space-between;
    margin-bottom: 30rpx;
    border-bottom: 1px solid #ccc;
    padding: 30rpx;
}
.aifxClose{
    width: 50rpx;
    height: 50rpx;
}
.aifxmain{
    overflow-y: auto;
    max-width: 600rpx;
    max-height: 700rpx;
    padding: 20rpx 10rpx;
    font-size: 28rpx;
    line-height: 1.8;
    color: #333;
    text-align: justify;
    white-space: pre-wrap;
    word-break: break-all;
    word-wrap: break-word;
}

/* Markdown样式支持 */
.aifxmain h1, .aifxmain view:nth-child(1) {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
    border-bottom: 1px solid #eee;
    padding-bottom: 10rpx;
}

.aifxmain h2, .aifxmain view:nth-child(2) {
    font-size: 34rpx;
    font-weight: bold;
    margin-bottom: 16rpx;
    padding-bottom: 8rpx;
}

.aifxmain h3, .aifxmain view:nth-child(3) {
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 14rpx;
}

.aifxmain h4, .aifxmain h5, .aifxmain h6 {
    font-size: 30rpx;
    font-weight: bold;
    margin-bottom: 12rpx;
}

.aifxmain p, .aifxmain view {
    margin-bottom: 10rpx;
}

.aifxmain ul, .aifxmain ol {
    padding-left: 40rpx;
    margin-bottom: 16rpx;
}

.aifxmain li {
    margin-bottom: 8rpx;
}

.aifxmain code {
    background-color: #f6f8fa;
    padding: 4rpx 8rpx;
    border-radius: 6rpx;
    font-family: monospace;
}

.aifxmain pre {
    background-color: #f6f8fa;
    padding: 20rpx;
    border-radius: 10rpx;
    margin-bottom: 16rpx;
    overflow-x: auto;
}

.aifxmain blockquote {
    border-left: 8rpx solid #ddd;
    padding: 16rpx;
    background-color: #f9f9f9;
    margin: 16rpx 0;
    color: #666;
}

.aifxmain table {
    border-collapse: collapse;
    width: 100%;
    margin-bottom: 16rpx;
}

.aifxmain th, .aifxmain td {
    border: 1px solid #ddd;
    padding: 12rpx;
    text-align: left;
}

.aifxmain th {
    background-color: #f5f7fa;
    font-weight: bold;
}

.aifxmain a {
    color: #0366d6;
    text-decoration: underline;
}

.aifxmain hr {
    border: none;
    border-top: 1px solid #eee;
    margin: 16rpx 0;
}
.poi{
    color: #999999;
    font-size: 20rpx;
    letter-spacing: 2rpx;
}