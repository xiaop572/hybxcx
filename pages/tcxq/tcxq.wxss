/* pages/tcxq/tcxq.wxss */

@import "../../wxParse/wxParse/wxParse.wxss";

page {
  background-color: #f2f2f2;
}

/* swiper 轮播图样式 */
.swiper {
  width: 100%;
  min-height: 400rpx; /* 设置最小高度，防止初始状态不显示 */
}

.swiper image {
  width: 100%;
  display: block;
}

/* 轮播图占位样式 */
.swiper-placeholder {
  width: 100%;
  height: 400rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.headline {
  width: 100%;
  height: 210rpx;
  background-color: #fff;
  padding: 40rpx;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.headline .title {
  display: block;
  font-weight: bold;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.xiaoliang {
  position: absolute;
  right: 50rpx;
  bottom: 40rpx;
  font-size: 30rpx;
  color: #888;
}

.headline .price {
  display: block;
  margin-top: 20rpx;
  color: red;
  font-weight: bold;
  position: absolute;
  left: 40rpx;
  bottom: 40rpx;
}
.headline .daoyuanfu {
  display: block;
  margin-top: 20rpx;
  color: red;
  font-weight: bold;
  position: absolute;
  left: 40rpx;
  bottom: 10rpx;
}
.dingjin .daoyuanfu{
  color: #333;
  font-size: 28rpx;
}
.dingjin .daoyuanfu text{
  color: red;
}
.dingjin .price{
  color: #333;
  bottom: 60rpx !important;
  font-size: 28rpx;
}
.dingjin .price text{
  color: red;
  vertical-align: middle;
}

.details {
  overflow: hidden;
  margin-top: 20rpx;
  background-color: #fff;
}

.details-title {
  padding: 40rpx;
  border-bottom: 1px solid #eee;
}

.footer {
  background: #fff;
  height: 100rpx;
  position: fixed;
  bottom: 0;
  width: 100%;
  text-align: right;
}

.buyBtn {
  height: 100rpx;
  line-height: 100rpx;
  display: inline-block;
  padding: 0 40rpx;
  color: #Fff;
  background-color: red;
  cursor: pointer;
}

.details-content {
  padding-bottom: 100rpx;
}

.details-content image {
  width: 100%;
}

.icon {
  float: left;
  font-size: 30rpx;
  color: #666;
  margin-top: 8rpx !important;
  margin-left: 60rpx !important;
  text-align: center;
  width: auto !important;
  padding: 0;

}

.icon image {
  display: block;
  margin: auto;
}

.kficon {
  width: 50rpx;
}

.icon text {
  font-size: 26rpx;
}

.specBox {
  width: 100%;
  height: 100%;
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  background: rgba(0, 0, 0, 0.8);
}

.spec {
  position: absolute;
  bottom: 0;
  width: 100%;
  max-height: 80vh;
  min-height: 580rpx;
  background-color: #fff;
  border-radius: 40rpx 40rpx 0 0;
  display: flex;
  flex-direction: column;
}

.specProImg {
  width: 200rpx;
}

.proinfoLeft {
  float: left;
  margin: 30rpx 30rpx 10rpx 30rpx;
}

.proinforight {
  margin-top: 30rpx;
  height: 200rpx;

}

.specPrice {
  display: block;
  font-weight: bold;
  color: red;
  font-size: 40rpx;
  margin-top: 90rpx;
}

.spectishi {
  color: #666;
}

.specList {
  margin: 0 30rpx 0 30rpx;
  padding: 20rpx 0 0 0;
  border-top: 1px solid #eee;
  flex: 1;
  overflow-y: auto;
  max-height: 300rpx;
}

.specSel {
  font-weight: bold;
}

.specItemList {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.specItem {
  font-size: 28rpx;
  background: #faf8fb;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.specNext {
  margin: 40rpx 30rpx 30rpx 30rpx;
  background-color: #fa4f48;
  text-align: center;
  color: #fff;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 70rpx;
  flex-shrink: 0;
}

.active{
  background:#fa4f48;
  color: #fff;
}

.miaoshaInfo{
  height: 140rpx;
  position: relative;
  overflow: hidden;
}
.seckillPrice{
  color: #fff;
  position: absolute;
  left: 0;
  padding-left: 30rpx;
  top: 0;
  width: 340rpx;
  font-size: 40rpx;
  height: 140rpx;
  line-height: 140rpx;
  background-color: #ff402d;
  overflow: initial;
  z-index: 999;
}
.seckillPrice .sPrice{ 
  font-size: 60rpx;
}
.jt{
  display: block;
  content:"";
  width: 140rpx;
  height: 140rpx;
  position: absolute;
  left: 270rpx;
  top: 0;
  background-color:#ff402d;
  border-radius: 20rpx;
  transform: rotate(45deg);
}
.yuanjia{
  font-weight: normal;
  color: #fefefe;
  font-size: 30rpx;
  margin-left: 20rpx;
  text-decoration: line-through;
}
.originPrice{
  color: #fffeff;
  position: absolute;
  left: 30rpx;
  top: 80rpx;
  font-size: 32rpx;
}
.limitTime{
  color: #b71520;
  font-size: 26rpx;
  background:linear-gradient(to right,#f9c1cc,#fef2f2,#f7ffff,#b9e7ff);
  padding: 0 30rpx;
  border-radius: 50rpx;
  display: inline-block;
  margin-left: 30rpx;
}
.residue{
  color: #fffeff;
  position: absolute;
  left: 280rpx;
  top: 80rpx;
  font-size: 32rpx;
}
.xxianshi{
  position: absolute;
  right: 0;
  top: 0;
  height:100%;
  background-color: #f4efec;
  border-radius: 20rpx 0 0 20rpx;
  width: 400rpx;
  box-sizing: border-box;
  padding: 20rpx 10rpx 20rpx 80rpx;
  font-weight: bold;
  font-size: 28rpx;
  z-index: -10;
  text-align: center;
}
.znz{
  width: 30rpx;
  vertical-align: middle;
  margin-right: 10rpx;
}
.cap{
  vertical-align: middle;
  color: #ff3e2c;
  letter-spacing: 5rpx;
}
.residueTime{
  color: #fff;
  margin-top: 10rpx;
  font-size: 26rpx;
}
.residueTime .black{
  background-color: #fe3f2d;
  display: inline-block;
  font-weight: normal;
  padding:0 5rpx;
  border-radius: 5rpx;
}
.residueTime .d{
  margin: 0 5rpx;
  color:#fe3f2d;
}

/* 感叹号图标样式 */
.info-icon {
  width: 32rpx;
  height: 32rpx;
  margin-left: 10rpx;
  vertical-align: middle;
  opacity: 0.6;
}

/* 弹框样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  animation: modalShow 0.3s ease-out;
}

@keyframes modalShow {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  padding: 40rpx 40rpx 20rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #eee;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.close-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.6;
}

.modal-body {
  padding: 40rpx;
}

.modal-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.modal-footer {
  padding: 20rpx 40rpx 40rpx 40rpx;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #ff4757;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  text-align: center;
  cursor: pointer;
  transition: background-color 0.3s ease;
  box-sizing: border-box;
}

.modal-btn:active {
  background-color: #e63946;
  transform: scale(0.98);
}