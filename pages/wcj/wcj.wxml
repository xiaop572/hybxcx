<!--pages/zzinfo/zzinfo.wxml-->
<view class="main">
  <image src="https://wx.pmc-wz.com/materials/kdlogo.png" mode="widthFix" class="logo"></image>
  <image src="https://wx.pmc-wz.com/materials/youzhi.png" mode="widthFix" class="youzhi"></image>
  <!-- <image src="https://wx.pmc-wz.com/materials/shengming.png" mode="widthFix" class="shengming"></image> -->
  <view class="title">
    {{options.title}}
  </view>
  <view  class="hint">
    <text >温馨提示：请填写真实身份信息!</text>
  </view>
  <view class="containers"> 
    <view class="name inTxt">
      <view class="caption">姓名<i></i></view>
      <input type="text" class="int" model:value="{{name}}"/>
    </view>
    <view class="name inTxt">
      <view class="caption">手机号<i></i></view>
      <input type="number" class="int" model:value="{{phone}}"/>
    </view>
  <view class="submitBtn" bindtap="rfukuan">确认</view>
  <image src="https://wx.pmc-wz.com/materials/wcjxx.jpg" mode='widthFix' class="wcjxx " wx:if="{{options.summary=='无痛'}}"></image>
  </view> 
</view>