/* pages/kaquan/kaquan.wxss */
page {
  height: 100%;
  background-color: #f5f5f5;
  position: fixed;
}

.navBox {
  /* 顶部tab盒子样式 */
  width: 90%;
  margin: auto;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 5%;
  position: relative;
}

.navBox view {
  /* 最后一个tab标题的样式 */
  padding-left: 10%;
}

.navBox view:first-child {
  /* 最后一个tab标题的样式 */
  padding-left: 0;
}

.titleBox {
  /* 未选中文字的样式 */
  color: #666666;
  font-size: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  letter-spacing: 3rpx;
}

.lineBox,
.notLineBox {
  /* 选中及未选中底线共同样式 */
  width: 32rpx;
  height: 8rpx;
  color: #2c68fa;
}

.fontColorBox,
.fontColorBox1 {
  /* 文字默认颜色 */
  color: #2c68fa;
  font-size: 36rpx;
  font-weight: 600;
}

.lineBox {
  /* 选中底线样式 */
  background: #2c68fa;
  margin-top: 5rpx;
  border-radius: 4rpx;
}

.kqBox {
  /* background: url("https://wx.pmc-wz.com/materials/kaquanBg.png") no-repeat; */
  background-size: 100% 100%;
  height: 100%;
}

.kapianList {
  background-color: #fff;
  width: 96%;
  margin:30rpx auto;
  box-sizing: border-box;
  padding: 20rpx;
  overflow: hidden;
  border-radius: 30rpx;
}

.kapianList image {
  width: 190rpx;
  display: block;
  margin: 20rpx auto 10rpx auto;
  box-shadow: 0px 1px 5px 1px #ddd;
  float: left;
}

.kapianList image:active {
  opacity: 0.8;
}
.proRight{
  margin-top: 24rpx;
  margin-left: 30rpx;
  width: 450rpx;
}
.goodsname {
  letter-spacing: 3rpx;
  font-size: 28rpx;
  display: block;
}
.spec-info {
  margin-top: 10rpx;
  padding: 8rpx 12rpx;
  background-color: #f8f9fa;
  border-radius: 6rpx;
  border-left: 3rpx solid #4c82fb;
}
.spec-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}
.spec-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}
.price{
  width: 100%;
  display: block;
  margin-top: 20rpx;
}
.btnlist {
  height: 80rpx;
  text-align: right;
  width: 100%;
  clear: both;
}

.swiperTtemBox {
  /* 底部内容样式 */
  height: calc(100% - 100rpx);
  overflow: scroll;
  font-size: 28rpx;
  -webkit-overflow-scrolling: touch;
}

.shiyong {
  font-size:24rpx;
  display: inline-block;
  background-color: #4c82fb;
  color: #fff;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 30rpx;
  margin-top: 10rpx;
  margin-right: 30rpx;
  vertical-align: middle;
  padding: 0 26rpx;
}
.shiyong2{
  font-size: 32rpx;
  display: inline-block;
  background-color: #f5a947;
  color: #fff;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 30rpx;
  margin-top: 10rpx;
  margin-right: 30rpx;
  vertical-align: middle;
  font-size: 28rpx;
  padding: 0 20rpx;
}
.zengsong {
  background-color: #fff;
  font-weight: normal;
  padding: 0;
  width: auto !important;
  font-size: 26rpx;
  display: inline-block !important;
  border: 1px solid #4c82fb;
  color: #4c82fb;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 30rpx;
  margin-top: 10rpx;
  margin-right: 30rpx;
  vertical-align: middle;
  padding: 0 20rpx;
}

.orderno {
  color: #999;
  display: block;
  padding-bottom: 10rpx;
  border-bottom: 1px solid #eee;
  margin-bottom: 10rpx;
}
.orderno1 {
  color: #767676;
  display: block;
  position: relative;
  top: 10rpx;
}
.proRight{
  float: left;
}
.zengkaList{
  background-color: #fff;
  width: 96%;
  margin:30rpx auto;
  box-sizing: border-box;
  padding: 20rpx;
  overflow: hidden;
  border-radius: 30rpx;
}
.zengkaList image {
  width: 175rpx;
  display: block;
  margin: 20rpx auto 0 auto;
  box-shadow: 0px 1px 5px 1px #ddd;
  float: left;
}
.zengkaList .goodsname{
  margin-top: 15rpx;

}
.zengkaList .orderno{
  border-bottom: 0;
}