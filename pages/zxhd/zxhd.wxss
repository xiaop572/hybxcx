/* pages/zxhd/zxhd.wxss */
.main {
  padding: 0;
  margin: 0;
}

.zxContainer {
  position: relative;
  background-color: #06408a;
}

.zxImg {
  width: 100%;
}

.shuru {
  width: 86%;
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  margin: auto;
  background-color: #06408a;
  height: 380rpx;
  background-image: url("https://wx.pmc-wz.com/materials/zxhdInBg.png");
  background-repeat: no-repeat;
  background-size: 100%;
  padding: 20rpx;
}

.shuru image {
  width: 100%;
}

.shurulist {
  position: absolute;
  top: 30rpx;
  left: 40rpx;
  color: #fff;
}

.type1 {
  width: 55%;
  float: left;
  margin-top: 30rpx;
}

.type2 {
  width: 40%;
  float: left;
  margin-top: 30rpx;
}

.type3 {
  float: left;
  margin-top: 40rpx;
}

.shurulist text {
  float: left;
}

.type1 input {
  border: 1px solid #fff;
  float: left;
  width: 60%;
  border-radius: 10rpx;
  box-sizing: border-box;
  padding: 0 10rpx;
}

.type2 input {
  border: 1px solid #fff;
  float: left;
  width: 50%;
  border-radius: 10rpx;
  box-sizing: border-box;
  padding: 0 10rpx;
}

.type3 input {
  border: 1px solid #fff;
  float: left;
  width: 65%;
  border-radius: 10rpx;
  box-sizing: border-box;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.yaoqing {
  letter-spacing: 9rpx;
}

.submit {
  background-color: #ec80a2;
  color: #fff;
  width: 240rpx !important;
  padding: 0 !important;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  margin: 0 auto;
  display: block;
  position: relative;
  top: 30rpx;
}

.ca {
  position: absolute;
  top: -20rpx;
  left: 30px;
  width: 200rpx !important;
}

.zhuanfa {
  position: absolute;
  bottom: 460rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.zhuanfa .icon {
  width: 40rpx;
  vertical-align: middle;
}

.zhuanfa .wenzi {
  vertical-align: middle;
  width: 80%;
}

.footerWenzi {
  background-color: #06408a;
  text-align: center;
  width: 88%;
  padding: 0 6% 60rpx 6%;
  margin: auto;
}

.footerWenzi text {
  text-align: center;
  color: #fff;
  font-size: 26rpx;
}

.modal-mask {
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0;
  left: 0;
  background: #000;
  z-index: 1001;
  -moz-opacity: 0.7;
  opacity: 0.70;
  filter: alpha(opacity=70);
  overflow: hidden;
}

.image-modal .modal-main {
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0;
  left: 0;
  padding: 15px;
  box-sizing: border-box;
  background-color: transparent;
  z-index: 1002;
}

.myQrcode,
.canvas-box {
  height: 100%;
  width: 100%;
  position: fixed;
  left: 0;
  top: 999999rpx;
}

.image {
  display: block;
  margin: auto;
}

.saveBtn {
  margin-top: 40rpx;
}

.btnList {
  width: 100%;
  text-align: center;
}

.btnList button {
  display: inline-block;
  width: 40% !important;
  font-size: 28rpx;
}

.hide {
  margin-right: 20rpx !important;
}

.myshare {
  position: absolute;
  right: 20rpx;
  bottom: 540rpx;
  width: 90rpx;
  background-color: #ec80a2;
  border-radius: 50%;
  padding: 10rpx;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  height: 90rpx;
}
.shareListBox{
  position: fixed;
  width: 92%;
  height: 90%;
  box-sizing: border-box;
  top: 5%;
  left: 4%;
  background-color: #06408a;
  border-radius: 20rpx;
  border: 8rpx dashed #ec80a2;
  overflow-y: auto;
  z-index: 1000;
}
.close{
  /* background-color: #ec80a2; */
  width: 80rpx;
  height: 80rpx;
  color: #fff;
  position: absolute;
  right: 0;
  top: 0;
  border-radius: 40rpx;
  font-size: 26rpx;
  text-align: center;
  line-height: 80rpx;
}
.shareListCaption{
  color: #fff;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 20rpx;
  letter-spacing: 5rpx;
}
.shareList{
  color: #fff;
}
.shareList text{
  width: 50%;
  display: inline-block;
  box-sizing: border-box;
  text-align: center;
  border-bottom: 1px solid #fff;
  line-height: 100rpx;
}