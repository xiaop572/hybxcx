page {
  height: 100%;
  background-color: #ededed;
}

.main {
  height:100%;
  overflow: hidden;
}

.captionBox {
  height: 40px;
  background-color: #fff;
  border-top: 1px solid #eee;
}

.chatBox {
  position: relative;
  overflow-y: auto;
  box-sizing: border-box;
  padding: 20rpx 0;
  transition: height 0.2s;
}

.inBox {
  border-top: 1px solid #ccc;
  box-sizing: border-box;
  background-color: #f7f7f7;
  position: relative;
  transition: height 0.2s;
}

.wordInputBox {
  height: 70px;
}

.iconLeft {
  width: 70rpx;
  position: absolute;
  height: 70px;
  left: 20rpx;
}

.iconLeft image {
  width: 100%;
  position: absolute;
  top: 0;
  bottom: 0;
  padding: 0;
  margin: auto;
}

.wordInput {
  background-color: #fff;
  height: 40px;
  width: 530rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
  position: absolute;
  top: 30rpx;
  left: 110rpx;
  border: 1px solid #eee;
  transition: width 0.3s;
}

.iconRight {
  width: 70rpx;
  position: absolute;
  height: 70px;
  right: 20rpx;
  top: 0;
}

.iconRight image {
  width: 100%;
  position: absolute;
  top: 0;
  bottom: 0;
  padding: 0;
  margin: auto;
}

.linkman {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  line-height: 40px;
}

.sendyuyin {
  background-color: #fff;
  position: absolute;
  top: 30rpx;
  left: 110rpx;
  height: 40px;
  width: 530rpx !important;
  font-weight: normal;
  text-align: center;
  border-radius: 10rpx;
}

.sendBtn {
  width: 160rpx !important;
  position: absolute;
  height: 70rpx;
  right: 20rpx;
  top: 18px;
  padding: 0;
  margin: 0;
  background-color: #07c160;
  color: #fff;
  font-weight: normal;
  font-size: 30rpx;
  line-height: 70rpx;
}

.sendyuyin:active {
  background-color: #07c160;
  color: #fff;
}

.chatBlock {
  width: 80%;
  margin: 30rpx auto 0 auto;
}

.myChat {
  text-align: right !important;
}

.myChat .content {
  background-color: #07c160 !important;
  color: #333;
}

.myChat .content::after {
  content: "";
  width: 0;
  height: 0;
  position: absolute;
  right: -15px;
  border-color: transparent transparent transparent #07c160;
  border-style: solid;
  border-width: 6px 8px;
  top: 15px;
}

.content {
  border-radius: 20rpx;
  background-color: #fff;
  display: inline-block;
  padding: 20rpx;
  position: relative;
}

.hisChat .content::before {
  content: "";
  width: 0;
  height: 0;
  border-color: transparent #fff transparent transparent;
  border-style: solid;
  border-width: 6px 8px;
  position: absolute;
  left: -15px;
  top: 15px;
}
.yinpinIcon{
  width:60rpx;
  vertical-align: text-top;
}
.time{
  margin-bottom: 10rpx;
  color: #666;
}
.subjoinBox{
  background-color: #fff;
  height: 200px;
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}
.subjoinItem{
  text-align: center;
  width: 100rpx;
}
.subjoinItem image{
  width: 100%;
}
.subjoinItem text{
  text-align: center;
  font-size: 26rpx;
  letter-spacing: 5rpx;
}
.uploadImage{
  width: 200rpx;
}
.magnifyBox{
  position: fixed;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
  background-color: rgba(0, 0, 0, 0.4);
}
.magnifyBox image{
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  margin: auto;
}