/* pages/realInfo/readlInfo.wxss */
page{
  height: 100%;
}
.streamer{
  display: block;
  width: 100%;
  text-align: center;
  font-size: 14px;
  padding: 10rpx 0;
  height: 60rpx;
  line-height: 60rpx;
  background: #f7e6c8;
  color: red;
}
.inputLine{
  overflow: hidden;
}
.inputLine text{
  display: block;
  padding: 20rpx;
  font-size: 14px;
}
.inputLine input{
  height: 2.6rem;
  padding: 0 20rpx;
  border-top: 1px solid #eee;
  border-bottom: 1px solid #eee;
}
button{
  width: 86% !important;
  margin-top: 40rpx;
}
.yinsi{
  color: blue;
  display: inline;
}
/* 隐私协议勾选框样式 */
.privacy-agreement {
  margin: 30rpx 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 10rpx;
}

.privacy-checkbox {
  display: flex;
  align-items: center;
  font-size: 14px;
}

.privacy-checkbox checkbox {
  margin-right: 10rpx;
  transform: scale(0.8);
}

.privacy-text {
  color: #333;
  margin-right: 5rpx;
}

.footer{
  width: 100%;
  position: absolute;
  bottom: 0;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
}