/* pages/experProgram/experProgram.wxss */
page {
  height: 100%;
  font-family: "微软雅黑";
}

.swiper {
  height: 100%;
}

swiper-item {
  position: relative;
}

.bg {
  background-repeat: no-repeat;
  background-size: 100% 100%;
}

.bg {
  background-repeat: no-repeat;
  background-size: 100% 100%;
  position: relative;
}

.liaojie {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  color: #fff;
  border: 2px solid #fff;
  border-radius: 40rpx;
  position: absolute;
  bottom: 200rpx;
  left: 0;
  right: 0;
  margin: auto;
}

.border {
  border: 2px solid #fff;
  border-radius: 40rpx;
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
}

.yuyue {
  color: #fff;
  position: absolute;
  left: 0;
  right: 0;
  bottom: 100rpx;
  margin: auto;
  text-align: center;
  background: none;
}

.yuyueBtn {
  color: #fff;
  position: absolute;
  left: 0;
  right: 0;
  bottom: 100rpx;
  margin: auto;
  text-align: center;
  background: #be1b24;
  border-radius: 50rpx;
  width: 80%;
  font-weight: normal;
}

.place {
  position: fixed;
  top: -700rpx;
  width: 100%;
  transition: all 0.6s ease;
  left: 0;
  right: 0;
  margin: auto;
}


.wicket {
  background-color: #fff;
  width: 80%;
  height: 620rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.show {
  top: 20%;
}
.activity {
  bottom: 0;
}

.wicketCaption {
  font-size: 50rpx;
  margin: 50rpx 0 0 40rpx;
  display: block;
}

.wicketList {
  padding: 0 40rpx;
  margin-top: 60rpx;
}

.left {
  color: #333;
  display: inline-block;
  width: 160rpx;
  vertical-align: middle;
}
.left1{
  color: #333;
  display: inline-block;
  width: 100%;
  vertical-align: middle;
}
.right {
  margin-left: 40rpx;
  color: #666;
  vertical-align: middle;
}

.rightBtn {
  width: 200rpx !important;
  padding: 0;
  margin: 0;
  display: inline-block;
  vertical-align: middle;
}