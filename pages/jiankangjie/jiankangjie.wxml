<!--pages/jiankangjie/jiankangjie.wxml-->
<view class="page-container">
  <!-- 顶部Banner大图 (整个顶部区域作为一张图) -->
  <image class="top-banner" src="https://wx.pmc-wz.com/materials/jkm7banner.png" mode="widthFix"></image>
  <image src="https://wx.pmc-wz.com/materials/jkm7yun.png" mode="widthFix" class="jkm7yun"/>

  <view class="lottery-section">
    <view class="lottery-machine">
      <image class="lottery-machine-bg" src="https://wx.pmc-wz.com/materials/jkm7zpbg.png" mode="widthFix"></image>
      <view class="lottery-grid">
        <view
          class="lottery-item {{activeLotteryIndex === index ? 'lottery-item-active' : ''}}"
          wx:for="{{lotteryPrizes}}"
          wx:key="id"
        >
          <image class="lottery-item-img" src="{{item.image}}" mode="widthFix"></image>
          <view wx:if="{{activeLotteryIndex === index}}" class="lottery-item-glow"></view>
        </view>
      </view>
      <view class="lottery-chance">
        <text>您有{{lotteryChance}}次抽奖机会</text>
        <view class="lottery-chance-tail"></view>
      </view>
      <image
        class="lottery-btn"
        src="https://wx.pmc-wz.com/materials/jkm7cjbtn.png"
        mode="widthFix"
        bindtap="startLottery"
      ></image>
    </view>
  </view>
<image src="https://wx.pmc-wz.com/materials/jkm7gz.png" mode="widthFix" class="jkm7gz"/>
  <view class="product-section">
    <view class="product-section-inner">
      <image src="https://wx.pmc-wz.com/materials/jkm7protitle.png" mode="widthFix" class="jkm7protitle"/>

      <!-- Tab 切换栏 -->
      <view class="tab-bar">
        <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-idx="0">整形专区</view>
        <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-idx="1">口腔专区</view>
        <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="onTabChange" data-idx="2">健康体检</view>
        <view class="tab-item {{currentTab === 3 ? 'active' : ''}}" bindtap="onTabChange" data-idx="3">产后修复</view>
      </view>
      <view class="product-content-panel">
        <!-- <image src="https://wx.pmc-wz.com/materials/jkm7mlqk.png" mode="widthFix" class="jkm7mlqk"/> -->
        <!-- 产品列表 -->
        <view class="product-grid">
          <view class="empty-tip" wx:if="{{products.length === 0}}">
            <text>暂无相关产品</text>
          </view>
          <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goProduct" data-id="{{item.id}}">
            <view class="product-img-wrap">
              <image class="product-img" src="https://wx.pmc-wz.com/hyb/images/{{item.picurl}}" mode="aspectFill" lazy-load="true"></image>
            </view>
            <view class="product-name">{{item.pictitle}}</view>
            <view class="product-bottom-row">
              <view class="product-price">
                <text class="price-symbol">¥</text>
                <text class="price-num">{{item.price}}</text>
              </view>
              <view class="buy-btn" catchtap="goProduct" data-id="{{item.id}}">立即抢购</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  <image src="https://wx.pmc-wz.com/materials/hkm7hxxhl.png" mode="widthFix" class="hkm7hxxhl" bindtap="openHxGiftModal"/>


  <!-- 礼包弹框 -->
  <view class="gift-mask" wx:if="{{showGiftModal}}">
    <view class="gift-modal gift-modal-image" catchtap="preventBubble">
      <image class="gift-poster-img" src="https://wx.pmc-wz.com/materials/jkm7jqyl.png" mode="widthFix"  bindtap="claimGift"></image>
    </view>
  </view>

  <view class="gift-mask" wx:if="{{showLotteryResult}}" bindtap="closeLotteryResult">
    <view class="lottery-result-modal" catchtap="preventBubble">
      <image class="lottery-result-bg" src="https://wx.pmc-wz.com/materials/jkm7jpbg.png" mode="widthFix"></image>
      <view class="lottery-result-content">
        <view class="lottery-result-title">恭喜您获得</view>
        <image class="lottery-result-img" src="{{lotteryResult.popupImage || lotteryResult.image}}" mode="widthFix"></image>
        <image class="lottery-result-btn" src="https://wx.pmc-wz.com/materials/jkm7jpbtn.png" mode="widthFix" bindtap="goMyCard"></image>
      </view>
    </view>
  </view>

  <view class="gift-mask" wx:if="{{showHxGiftModal}}" bindtap="closeHxGiftModal">
    <view class="hx-gift-modal" catchtap="preventBubble">
      <image class="hx-gift-modal-img" src="https://wx.pmc-wz.com/materials/jkm7hxl.png" mode="widthFix"></image>
      <view class="gift-close" bindtap="closeHxGiftModal">×</view>
    </view>
  </view>

</view>
