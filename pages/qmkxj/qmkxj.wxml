<view wx:if="{{!isyearinfo}}" class="tz">
  <view class="tzbox">
    <text class="tzcap">请填写以下信息</text>
    <view class="tzinp">
      <text>宝宝姓名：</text>
      <input type="text" model:value="{{xingming}}" />
    </view>
    <view class="tzinp">
      <text>宝宝年龄：</text>
      <input type="text" model:value="{{age}}" />
    </view>
    <view class="tzinp">
      <text>家长电话：</text>
      <input type="text" model:value="{{mobile}}" />
    </view>
    <view class="submit" bind:tap="submit">提交</view>
  </view>

</view>