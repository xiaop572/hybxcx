<view class="main">
  <image src="https://wx.pmc-wz.com/materials/qmkxjBanner.png" mode="widthFix" class="banner"></image>
  <image src="https://wx.pmc-wz.com/materials/qmkxjpro.gif" bindtap="rpro" mode="widthFix" class="nzpro"></image>
  <view class="tmbox">
    <view class="tm" wx:for="{{tmlist}}" wx:for-item="item" wx:key="idx" wx:for-index="idx" style="top:{{item.y}}rpx;left:{{item.x}}%;animation-delay:{{idx*3}}s">
      <image src="{{item.avatarUrl}}" mode="widthFix" />
      <text>{{item.xinmin}}</text>
      <text> 刚刚抢购成功</text>
    </view>
  </view>
