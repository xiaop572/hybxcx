page{
  background-color: #f5f5f5;
}
.article {
  width:100%;
}
.article .h2{
  font-weight: bold;
  font-size: 40rpx;
  width: 100%;
  padding: 0 5%;
  box-sizing: border-box;
  display: block;
  background-color: #fff;
}
.articleBlock {
  overflow: hidden;
  width: 90%;
  margin:40rpx auto 0 auto;
  background-color: #fff;
}

.articleImg {
  width: 100%;
}
.articleImg image{
  width: 100%;
}
.articleWord{
  padding: 30rpx 30rpx;
}