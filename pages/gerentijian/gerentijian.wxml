                bindtap="toggleMultiOption" data-field="familyCancers" data-value="白血病">F、白血病</view>
          <view class="option-item {{utils.includes(questionnaire.familyCancers, '脑瘤') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyCancers" data-value="脑瘤">G、脑瘤</view>
