          <view class="option-item {{utils.includes(questionnaire.familyCancers, '甲状腺癌') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyCancers" data-value="甲状腺癌">Q、甲状腺癌</view>
          <view class="option-item {{utils.includes(questionnaire.familyCancers, '皮肤癌') ? 'selected' : ''}}" 
