  </view>
</view>

<!-- 检前问卷弹窗 -->
<view class="questionnaire-modal" wx:if="{{showQuestionnaire}}">
  <view class="questionnaire-content">
    <view class="questionnaire-header">
      <text class="questionnaire-title">检前问卷</text>
      <view class="close-btn" bindtap="closeQuestionnaire">×</view>
    </view>
    
    <scroll-view class="questionnaire-body" scroll-y="true">
      <!-- 问题1：姓名 -->
      <view class="question-item">
        <view class="question-title">1、姓名</view>
        <input class="question-input" placeholder="请输入姓名" value="{{questionnaire.name}}" bindinput="onNameInput" />
      </view>

      <!-- 问题2：民族 -->
      <view class="question-item">
        <view class="question-title">2、民族</view>
        <view class="option-group">
          <view class="option-item {{questionnaire.ethnicity === '汉族' ? 'selected' : ''}}" 
                bindtap="selectOption" data-field="ethnicity" data-value="汉族">汉族</view>
          <view class="option-item {{questionnaire.ethnicity === '少数民族' ? 'selected' : ''}}" 
                bindtap="selectOption" data-field="ethnicity" data-value="少数民族">少数民族</view>
        </view>
      </view>

      <!-- 问题3：性别 -->
      <view class="question-item">
        <view class="question-title">3、性别</view>
        <view class="option-group">
          <view class="option-item {{questionnaire.gender === '男' ? 'selected' : ''}}" 
                bindtap="selectOption" data-field="gender" data-value="男">男</view>
          <view class="option-item {{questionnaire.gender === '女' ? 'selected' : ''}}" 
                bindtap="selectOption" data-field="gender" data-value="女">女</view>
        </view>
      </view>

      <!-- 问题4：出生日期 -->
      <view class="question-item">
        <view class="question-title">4、出生日期</view>
        <picker mode="date" value="{{questionnaire.birthDate}}" bindchange="selectDate">
          <view class="date-picker">
            {{questionnaire.birthDate || '请选择出生日期'}}
          </view>
        </picker>
      </view>

      <!-- 问题5：婚姻状况 -->
      <view class="question-item">
        <view class="question-title">5、婚姻状况</view>
        <view class="option-group">
          <view class="option-item {{questionnaire.maritalStatus === '未婚' ? 'selected' : ''}}" 
                bindtap="selectOption" data-field="maritalStatus" data-value="未婚">未婚</view>
          <view class="option-item {{questionnaire.maritalStatus === '已婚（含同居）' ? 'selected' : ''}}" 
                bindtap="selectOption" data-field="maritalStatus" data-value="已婚（含同居）">已婚（含同居）</view>
          <view class="option-item {{questionnaire.maritalStatus === '丧偶' ? 'selected' : ''}}" 
                bindtap="selectOption" data-field="maritalStatus" data-value="丧偶">丧偶</view>
          <view class="option-item {{questionnaire.maritalStatus === '离异' ? 'selected' : ''}}" 
                bindtap="selectOption" data-field="maritalStatus" data-value="离异">离异</view>
        </view>
      </view>

      <!-- 问题6：家族疾病史 -->
      <view class="question-item">
        <view class="question-title">6、您的父母或兄弟姐妹是否有以下明确诊断的疾病（可多选）</view>
        <view class="option-group multi-select">
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '高血压病') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="高血压病">A、高血压病</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '脑卒中') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="脑卒中">B、脑卒中</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '冠心病') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="冠心病">C、冠心病</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '外周血管病') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="外周血管病">D、外周血管病</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '心力衰竭') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="心力衰竭">E、心力衰竭</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '糖尿病') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="糖尿病">F、糖尿病</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '肥胖症') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="肥胖症">G、肥胖症</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '慢性肾脏疾病') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="慢性肾脏疾病">H、慢性肾脏疾病</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '慢性阻塞性肺病') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="慢性阻塞性肺病">I、慢性阻塞性肺病</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '骨质疏松') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="骨质疏松">J、骨质疏松</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '痛风') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="痛风">K、痛风</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '风湿免疫性疾病') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="风湿免疫性疾病">L、风湿免疫性疾病</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '精神疾病') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="精神疾病">M、精神疾病</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '其他') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="其他">N、其他</view>
          <view class="option-item {{utils.includes(questionnaire.familyDiseases, '以上均无') ? 'selected' : ''}}" 
                bindtap="toggleMultiOption" data-field="familyDiseases" data-value="以上均无">O、以上均无</view>
        </view>
      </view>

      <!-- 问题7：家族肿瘤史 -->
      <view class="question-item">
        <view class="question-title">7、您的父母或兄弟姐妹是否有以下明确诊断的恶性肿瘤（可多选）</view>
