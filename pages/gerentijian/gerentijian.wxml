<!--pages/zzinfo/zzinfo.wxml-->
<wxs module="utils">
  var includes = function(arr, value) {
    if (!arr || arr.length === 0) {
      return false;
    }
    for (var i = 0; i < arr.length; i++) {
      if (arr[i] === value) {
        return true;
      }
    }
    return false;
  };
  
  module.exports = {
    includes: includes
  };
</wxs>

<view class="main">
  <image src="https://wx.pmc-wz.com/materials/kdlogo.png" mode="widthFix" class="logo"></image>
  <image src="https://wx.pmc-wz.com/materials/youzhi.png" mode="widthFix" class="youzhi"></image>
  <!-- <image src="https://wx.pmc-wz.com/materials/shengming.png" mode="widthFix" class="shengming"></image> -->
  <view class="title">
    体检预约
  </view>
  <view class="hint">
    <text>温馨提示：请填写真实身份信息!</text>
  </view>
  <view class="containers">
    <view class="name inTxt">
      <view class="caption">姓名<i></i></view>
      <input type="text" class="int" model:value="{{xinmin}}" />
    </view>
    <view class="name inTxt">
      <view class="caption">手机号<i></i></view>
      <input type="number" class="int" model:value="{{mobile}}" />
    </view>
    <view class="name inTxt">
      <view class="caption">性别<i></i></view>
      <view class="section int">
        <picker mode="selector" value="{{index}}" range="{{sexList}}" bindchange="bindsexchange">
          <view style="height: 70rpx;line-height: 70rpx;" wx:if="{{!sex}}">请选择</view>
          <view class="picker">
            {{sex}}
          </view>
        </picker>
      </view>
    </view>
    <view class="name inTxt">
      <view class="caption">证件类型<i></i></view>
      <view class="section int">
        <picker mode="selector" value="{{index}}" range="{{sfztypelist}}" bindchange="bindsfzchange">
          <view style="height: 70rpx;line-height: 70rpx;" wx:if="{{!sfztype}}">请选择</view>
          <view class="picker">
            {{sfztype}}
          </view>
        </picker>
      </view>
    </view>
    <view class="name inTxt" wx:if="{{sfztype=='居民身份证' || sfztype==''}}">
      <view class="caption">证件号码<i></i></view>
      <input type="text" class="int" model:value="{{cardno}}" />
    </view>
    <view class="name inTxt" wx:if="{{sfztype==='护照号'}}">
      <view class="caption">出生年月<i></i></view>
      <view class="section int">
        <picker mode="date" value="{{index}}" range="{{sfztypelist}}" bindchange="bindcsnychange">
          <view style="height: 70rpx;line-height: 70rpx;" wx:if="{{!cardno}}">请选择</view>
          <view class="picker">
            {{cardno}}
          </view>
        </picker>
      </view>
    </view>
    <view class="name inTxt">
      <view class="caption">婚姻状况<i></i></view>
      <view class="section int">
        <picker mode="selector" value="{{index}}" range="{{array}}" bindchange="bindhunchange">
          <view style="height: 70rpx;line-height: 70rpx;" wx:if="{{!hunyin}}">请选择</view>
          <view class="picker">
            {{hunyin}}
          </view>
        </picker>
      </view>
    </view>
    <view class="name inTxt">
      <view class="caption">体检套餐<i></i></view>
      <view class="section int">
        <picker mode="selector" value="{{product}}" range="{{tjlist}}" bindchange="bindtjchange" range-key="goodsname">
          <view style="height: 70rpx;line-height: 70rpx;" wx:if="{{!product}}">请选择</view>
          <view class="picker">
            {{product}}
          </view>
        </picker>
      </view>
    </view>
    <view wx:for="{{txlist}}" wx:for-item="item" wx:key="idx" wx:for-index="idx" class="txrenyuan"  wx:if="{{tjyycs>1}}">
      {{item.xinmin}}
      <image src="https://wx.pmc-wz.com/materials/txdel.png" mode="widthFix" bind:tap="deltx" data-index="{{idx}}" />
    </view>
    <view class="addtx" bind:tap="showtx" wx:if="{{tjyycs>1}}">添加同行体检人员</view>
    <view class="name inTxt">
      <view class="caption">预约时间<i></i></view>
      <view class="section int">
        <picker mode="selector" value="{{time}}" bindchange="bindTimeChange" range="{{timeList}}" range-key="sdate">
          <view style="height: 70rpx;line-height: 70rpx;" wx:if="{{!time}}">请选择</view>
          <view class="picker">
            {{time}}
          </view>
        </picker>
      </view>
    </view>
    <view class="name inTxt" wx:if="{{njvis}}">
      <view class="caption">内镜时间<i></i></view>
      <view class="section int">
        <picker mode="selector" value="{{njtime}}" bindchange="bindNjTimeChange" range="{{njtimeList}}" range-key="sdate">
          <view style="height: 70rpx;line-height: 70rpx;" wx:if="{{!njtime}}">请选择</view>
          <view class="picker">
            {{njtime}}
          </view>
        </picker>
      </view>
    </view>
    <view class="submitBtn" bindtap="rtijiao">提交</view>
    <image src="https://wx.pmc-wz.com/materials/wcjxx.jpg" mode='widthFix' class="wcjxx " wx:if="{{options.summary=='无痛'}}"></image>
  </view>
</view>
