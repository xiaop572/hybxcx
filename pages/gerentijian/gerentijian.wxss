/* 检前问卷弹窗样式 */
.questionnaire-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: white;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.questionnaire-content {
  width: 100%;
  height: 100%;
  background-color: white;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.questionnaire-header {
  padding: 15px 15px 10px 15px;
  border-bottom: 1px solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f8f9fa;
  position: relative;
  box-sizing: border-box;
  width: 100%;
}

.questionnaire-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.questionnaire-body {
  flex: 1;
  padding: 15px;
  overflow-y: auto;
  box-sizing: border-box;
  width: 100%;
}

.close-btn {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background-color: #ddd;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 18px;
  color: #666;
  cursor: pointer;
}



.question-item {
  margin-bottom: 25rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  width: 100%;
}

.question-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
  line-height: 1.4;
  word-wrap: break-word;
}

.question-input {
  width: 100%;
  height: 70rpx;
  padding: 0 15rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.question-input:focus {
  border-color: #2196F3;
  background-color: #fff;
}

.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.option-group.multi-select {
  flex-direction: column;
  gap: 8rpx;
}

.option-item {
  padding: 12rpx 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #fafafa;
  text-align: center;
  transition: all 0.3s ease;
  cursor: pointer;
  box-sizing: border-box;
  word-wrap: break-word;
  max-width: 100%;
}

.multi-select .option-item {
  text-align: left;
  border-radius: 8rpx;
  padding: 15rpx;
  width: 100%;
}

/* 选中状态样式 - 最高优先级 */
.option-item.selected,
.question-item .option-item.selected,
.option-group .option-item.selected,
.multi-select .option-item.selected,
view.option-item.selected,
.question-item .option-group .option-item.selected,
.question-item .multi-select .option-item.selected {
  background-color: #007aff !important;
  background: #007aff !important;
  color: white !important;
  border-color: #007aff !important;
  border: 2rpx solid #007aff !important;
  font-weight: bold !important;
  box-shadow: 0 2rpx 4rpx rgba(0, 122, 255, 0.3) !important;
}

.date-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 0 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  background-color: #fafafa;
  display: flex;
  align-items: center;
  color: #666;
  box-sizing: border-box;
}

.questionnaire-footer {
  padding: 15px 15px 50px 15px;
  border-top: 1px solid #eee;
  display: flex;
  gap: 12px;
  background-color: #f8f9fa;
  position: relative;
  bottom: 0;
  box-sizing: border-box;
  width: 100%;
}

.footer-btn {
  flex: 1;
  height: 44px;
  border-radius: 6px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 15px;
  font-weight: 500;
  box-sizing: border-box;
}

.skip-btn {
  background-color: #f5f5f5;
  color: #666;
  border: 1px solid #ddd;
}

.submit-btn {
  background-color: #007aff;
  color: white;
  border: none;
}