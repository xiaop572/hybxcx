/* subpackages/yiliaofuwu/yiliaofuwu.wxss */
page {
  background: #f2f2f2;
}
.myList{
  padding-top: 50rpx;
  min-height:240rpx;
  background: #fff;
  position: relative;
  top: -20rpx;
  padding-bottom: 20rpx;
  border-radius: 20rpx;
  width: 92%;
  margin: auto;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  padding: 20rpx 40rpx;
  overflow: hidden;
  box-sizing: border-box;
}
.myCaption{
  margin-top: 10rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-bottom: 1px solid #eee;
  width: 100%;
  display: block;
}
.myIcon{
  width: 25%;
  display: inline-block;
  text-align: center;
  margin-top: 26rpx;
  font-size: 12px;
}
.myIcon image{
  width: 100rpx;
  display: block;
  margin:10rpx auto;
}