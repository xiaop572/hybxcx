  <view class="youxuanBox">
    <view class="youxuanCaption">
      <view class="youLeft">
        <image src="https://wx.pmc-wz.com/materials/whiteXin.png" mode="widthFix"></image>
      </view>
      <view class="youRight">和平故事</view>
    </view>
    <video src="https://wx.pmc-wz.com/materials/xcp.mp4" class="xcp"></video>
  </view>
  <swiper indicator-active-color="#fff" indicator-dots="true" autoplay="true" interval="8000" style="height:400rpx" class="carousel2">
    <swiper-item>
      <image src="https://wx.pmc-wz.com/materials/zxsw.png" mode="widthFix" class="newBanner2"></image>
    </swiper-item>

    <swiper-item>
      <image src="https://wx.pmc-wz.com/materials/yzsw.png" mode="widthFix" class="newBanner2"></image>
    </swiper-item>
    <swiper-item>
      <image src="https://wx.pmc-wz.com/materials/tjsw.png" mode="widthFix" class="newBanner2"></image>
    </swiper-item>
    <swiper-item>
      <image src="https://wx.pmc-wz.com/materials/cksw.png" mode="widthFix" class="newBanner2"></image>
    </swiper-item>
    <swiper-item>
      <image src="https://wx.pmc-wz.com/materials/kqzx.png" mode="widthFix" class="newBanner2"></image>
    </swiper-item>
    <swiper-item>
      <image src="https://wx.pmc-wz.com/materials/gkzx.png" mode="widthFix" class="newBanner2"></image>
    </swiper-item>
    <swiper-item>
      <image src="https://wx.pmc-wz.com/materials/ebzx.png" mode="widthFix" class="newBanner2"></image>
    </swiper-item>
    <swiper-item>
      <image src="https://wx.pmc-wz.com/materials/myg.png" mode="widthFix" class="newBanner2"></image>
    </swiper-item>
  </swiper>
  <image src="https://wx.pmc-wz.com/materials/footer.png" mode="widthFix" class="footer"></image>
  <view class="setnickBox" wx:if="{{setnickvis}}">
    <view class="setnickMain">
      <view class="setnickCaption">设置昵称</view>
      <input type="text" placeholder="1-6个汉字" class="setnickInput" model:value="{{nickname}}" />
      <button class="setnickBtn" bindtap="setnick">确定</button>
    </view>
  </view>
</view>
<!-- 护侨弹窗  -->
<view class="popup {{showCard ? 'show' : ''}}" wx:if="{{showCard}}">
  <canvas type="2d" id="animCanvas"></canvas>
  <view class="card">
    <image src="https://wx.pmc-wz.com/materials/hqcard.png" mode="widthFix" class="hqcard" />
    <view class="blue-button" bind:tap="jkhq2">立即进入</view>
  </view>
</view>