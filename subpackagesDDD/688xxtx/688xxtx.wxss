page {
  background-color: #f5f5f5;
}

.container {
  width: 100%;
  margin: 0;
  padding: 0;
}

/* 顶部banner样式 */
.banner {
  width: 100%;
  position: relative;
  height: 200px;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
  clip-path: ellipse(90% 92% at 50% 0%);
}

.show{
  width: 93%;
  background: linear-gradient(to bottom ,#d0eefd 0%,#fff 20%);
  text-align: center;
  border-radius: 20rpx;
  position: relative;
  top: -30rpx;
  padding-top: 20rpx;
  box-shadow: 0 0 10rpx 0 #c2e9ff;
}

/* 开卡立享以下权益 */
.card-title {
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  flex-direction: row;
}
.line2{
  height: 1px;
  background: linear-gradient(to left,#000000 5%,#f0faff 30%);
  flex: 1;
  margin: 20rpx;
}
.line1{
  height: 1px;
  background: linear-gradient(to right,#000000 5%,#f0faff 30%);
  flex: 1;
  margin: 20rpx;
}

.icon-item{
  width: 190rpx;
  height: 190rpx;
  margin: 19rpx;
}
.linex{
  border-bottom:1px dashed #d6d6d6;
  margin:40rpx 30rpx;
}
.form{
  background-color: #fff;
  padding: 0 30rpx;
  width: 85%;
  border-radius: 20rpx;
  box-shadow: 0 0 10rpx 0 #c2e9ff;
}

.form-input{
  background-color: #f3f3f3;
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 60rpx;
  padding: 0 45rpx;
  font-size: 28rpx;
  letter-spacing: 10rpx;
}

.form-input:first-child{
  background-color: #f3f3f3;
  margin-top: 40rpx;
  height: 80rpx;
}
.form-input2{
  background-color: #f3f3f3;
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 60rpx;
  padding: 0 45rpx;
  font-size: 28rpx;
  /* letter-spacing: 10rpx; */
}


.ka{
  background-color: #0f60ca;
  color: #fff;
  font-weight:normal;
  height: 75rpx;
  font-size: 30rpx;
  border-radius: 50rpx;
  margin: 40rpx;
  line-height: 45rpx;
  letter-spacing:7rpx;
}