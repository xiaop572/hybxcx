page {
    height: 91%;
    background-color: #ededed;
}

.container {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 0;
    margin: 0;
}

/* 聊天区域样式 */
.chat-container {
    flex: 1;
    padding: 15rpx 15rpx;
    box-sizing: border-box;
    overflow-y: auto;
    margin: 5px 0;
}

.chat-list {
    padding-bottom: 10px;
}

.chat-item {
    display: flex;
    margin-bottom: 20px;
}

.chat-left {
    justify-content: flex-start;
}

.chat-right {
    justify-content: flex-end;
}

.chat-avatar {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
}

.chat-avatar image {
    width: 100%;
    height: 100%;
}

.chat-content {
    max-width: 70%;
    margin: 0 10px;
}

.chat-bubble {
    padding: 10px 15px;
    border-radius: 4px;
    font-size: 16px;
    line-height: 1.5;
    word-break: break-all;
}

.chat-left .chat-bubble {
    background-color: #ffffff;
    border-top-left-radius: 0;
}

.chat-right .chat-bubble {
    background-color: #95ec69;
    border-top-right-radius: 0;
}

/* 底部输入区域样式 */
.input-area {
    display: flex;
    padding: 20rpx 50rpx;
    background-color: #f5f5f7;
    border-top: 1px solid #ddd;
    align-items: flex-end;
    position: fixed;
    bottom: 30rpx;
    width: 100%;
}

.input-box {
    flex: 1;
    background-color: #ffffff;
    border-radius: 4px;
    padding: 8rpx 40rpx;
    margin: 0 20rpx;
    max-height: 120rpx;
    overflow-y: auto;
}

.message-input {
    width: 100%;
    min-height: 20px;
    max-height: 80px;
    font-size: 16px;
    line-height: 1.2;
    padding: 7rpx 0;
}

.tool-item image {
    width: 100%;
    height: 100%;
}

.send-btn {
    width: 60px;
    height: 65rpx;
    line-height: 36px;
    text-align: center;
    background-color: #07c160;
    color: #fff;
    border-radius: 4px;
    font-size: 15px;
    margin-right: 20rpx;
}

.picicon {
    width: 50rpx;
    height: 50rpx;
    margin: 0 20rpx 0 0;
}